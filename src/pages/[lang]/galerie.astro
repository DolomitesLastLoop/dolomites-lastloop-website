---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "@layouts/BaseLayout.astro";
import { useTranslations, type Lang } from "@i18n/utils";
import galleryManifest from "../../data/gallery-manifest.json";

// width/height aus dem Manifest (scripts/gallery-manifest.mjs), damit die
// Masonry nicht bei jedem Lazy-Load neu layoutet
const dims = galleryManifest as Record<string, [number, number]>;

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

const imagesDir = path.join(process.cwd(), "public", "images");
let files: string[] = [];
try {
  files = fs.readdirSync(imagesDir).filter((f) => {
    if (!/\.(jpe?g|png|webp)$/i.test(f)) return false;
    if (f.toLowerCase() === "logo.jpeg" || f.toLowerCase() === "logo.png") return false;
    if (f.startsWith(".")) return false;
    return true;
  });
} catch (err) {
  console.error("Gallery: cannot read images dir", err);
}

// Bucket day / night.
// HHW0xxx (low numbers from a fresh sensor cycle) = night.
// Named "night-*", "emotion-smile", "portrait-exhausted" = night.
// Everything else = day.
const isNight = (name: string) => {
  if (/^night-/i.test(name)) return true;
  if (/^emotion-smile/i.test(name)) return true;
  if (/^portrait-exhausted/i.test(name)) return true;
  // raw Wisthaler night batch
  if (/HHW0[0-2]\d{2}\.jpg$/i.test(name)) return true;
  return false;
};

// Deduplicate: the 10 semantic-named photos are copies of raw originals.
// Skip the raw originals if their semantic version exists.
const semanticRawMap: Record<string, string> = {
  "HW80448.jpg": "hero-start.jpg",
  "HW89652.jpg": "day-running-1.jpg",
  "HW80475.jpg": "day-running-2.jpg",
  "HW89733.jpg": "day-runner-portrait.jpg",
  "HHW6300.jpg": "bib-detail.jpg",
  "HHW0023.jpg": "night-runners.jpg",
  "HHW0161.jpg": "night-camp.jpg",
  "HHW0097.jpg": "night-headlamp.jpg",
  "HHW9554.jpg": "emotion-smile.jpg",
  "HHW8544.jpg": "portrait-exhausted.jpg",
};
const semanticSet = new Set(Object.values(semanticRawMap));
files = files.filter((f) => {
  for (const [suffix] of Object.entries(semanticRawMap)) {
    if (f.endsWith(suffix) && semanticSet.has(semanticRawMap[suffix]) && files.includes(semanticRawMap[suffix])) {
      return false;
    }
  }
  return true;
});

const day = files.filter((f) => !isNight(f)).sort();
const night = files.filter((f) => isNight(f)).sort();

const encodeSrc = (f: string) =>
  "/images/" + encodeURIComponent(f);

// Larger tiles for selected highlights for masonry rhythm
const isLarge = (idx: number) => idx % 7 === 0;
---

<BaseLayout
  lang={lang}
  title={t("gallery.title")}
  description={t("gallery.intro")}
>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t("gallery.subtitle")}</p>
      <h1>{t("gallery.title")}</h1>
      <p class="section-lead">{t("gallery.intro")}</p>
      <p class="text-dim">{t("gallery.credit")}</p>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <div class="section-divider reveal">
        <span class="dot"></span>
        <h2>{t("gallery.section.day")}</h2>
        <span class="count">{day.length}</span>
        <span class="line"></span>
      </div>

      {
        day.length === 0 ? (
          <p class="text-dim">—</p>
        ) : (
          <div class="masonry">
            {day.map((f, idx) => (
              <figure
                class={`tile ${isLarge(idx) ? "tile-large" : ""}`}
                data-src={encodeSrc(f)}
                data-name={f}
                data-alt={f}
              >
                <img
                  src={encodeSrc(f)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width={dims[f]?.[0]}
                  height={dims[f]?.[1]}
                />
                <a
                  class="tile-dl"
                  href={encodeSrc(f)}
                  download={f}
                  aria-label={t("gallery.download")}
                  title={t("gallery.download")}
                  onclick="event.stopPropagation()"
                >
                  ↓
                </a>
                <span class="hover-overlay">{t("gallery.credit")}</span>
              </figure>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-wide">
      <div class="section-divider reveal">
        <span class="dot dot-night"></span>
        <h2>{t("gallery.section.night")}</h2>
        <span class="count">{night.length}</span>
        <span class="line"></span>
      </div>

      {
        night.length === 0 ? (
          <p class="text-dim">—</p>
        ) : (
          <div class="masonry">
            {night.map((f, idx) => (
              <figure
                class={`tile ${isLarge(idx) ? "tile-large" : ""}`}
                data-src={encodeSrc(f)}
                data-name={f}
                data-alt={f}
              >
                <img
                  src={encodeSrc(f)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width={dims[f]?.[0]}
                  height={dims[f]?.[1]}
                />
                <a
                  class="tile-dl"
                  href={encodeSrc(f)}
                  download={f}
                  aria-label={t("gallery.download")}
                  title={t("gallery.download")}
                  onclick="event.stopPropagation()"
                >
                  ↓
                </a>
                <span class="hover-overlay">{t("gallery.credit")}</span>
              </figure>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <div
    class="lightbox"
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Lightbox"
    hidden
  >
    <button class="lb-close" type="button" aria-label={t("gallery.close")}>
      ✕
    </button>
    <a
      id="lb-download"
      class="lb-dl"
      href="#"
      download
      aria-label={t("gallery.download")}
      title={t("gallery.download")}
    >
      ↓ <span class="lb-dl-text">{t("gallery.download")}</span>
    </a>
    <button class="lb-nav lb-prev" type="button" aria-label="Previous">
      ‹
    </button>
    <figure class="lb-stage">
      <img id="lb-image" src="" alt="" />
      <figcaption>
        <span class="lb-credit">{t("gallery.credit")}</span>
      </figcaption>
    </figure>
    <button class="lb-nav lb-next" type="button" aria-label="Next">›</button>
  </div>
</BaseLayout>

<style>
  .page-head {
    padding: var(--space-9) 0 var(--space-5);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .section-divider {
    display: grid;
    grid-template-columns: auto auto auto 1fr;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .section-divider h2 {
    margin: 0;
  }
  .section-divider .count {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
  .section-divider .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
    display: inline-block;
  }
  .section-divider .dot-night {
    background: #1a2a3a;
  }
  .section-divider .line {
    height: 1px;
    background: var(--color-border);
    width: 100%;
  }

  .masonry {
    columns: 4 240px;
    column-gap: var(--space-4);
  }
  .masonry .tile {
    break-inside: avoid;
    margin: 0 0 var(--space-4);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    cursor: zoom-in;
    background: var(--color-bg-alt);
    box-shadow: var(--shadow-card);
    /* Offscreen-Kacheln kosten kein Layout/Paint — entscheidend gegen
       Scroll-Jank bei ~190 Bildern */
    content-visibility: auto;
    contain-intrinsic-size: auto 320px;
    /* nur transform animieren; box-shadow-Transition ist Paint-teuer × 190 */
    transition: transform var(--transition);
  }
  .tile img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 800ms var(--ease-emphasis);
  }
  .tile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }
  .tile:hover img {
    transform: scale(1.04);
  }
  .tile .hover-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: var(--space-4) var(--space-4) var(--space-3);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    background: linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0) 100%
    );
    opacity: 0;
    transition: opacity var(--transition);
    pointer-events: none;
  }
  .tile:hover .hover-overlay,
  .tile:focus-within .hover-overlay {
    opacity: 1;
  }

  .tile-dl {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-primary);
    font-size: 1.1rem;
    line-height: 1;
    font-weight: 700;
    text-decoration: none;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity var(--transition), transform var(--transition),
      background var(--transition);
    z-index: 3;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
  }
  .tile:hover .tile-dl,
  .tile:focus-within .tile-dl {
    opacity: 1;
    transform: none;
  }
  .tile-dl:hover {
    background: #ffffff;
    color: var(--color-primary-hover);
    transform: scale(1.05);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(10, 14, 22, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
    opacity: 0;
    transition: background 280ms var(--ease-emphasis),
      opacity 280ms var(--ease-emphasis);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox.is-open {
    background: rgba(10, 14, 22, 0.95);
    opacity: 1;
  }
  .lb-stage {
    margin: 0;
    max-width: min(94vw, 1500px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transform: scale(0.85);
    transition: transform 380ms var(--ease-emphasis);
  }
  .lightbox.is-open .lb-stage {
    transform: scale(1);
  }
  .lb-stage img {
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    border-radius: var(--radius);
    background: #000;
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .lb-stage {
      transition: none !important;
    }
    .lb-stage {
      transform: none;
    }
  }
  .lb-stage figcaption {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.85rem;
  }
  .lb-credit {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .lb-dl {
    position: absolute;
    top: var(--space-4);
    right: calc(var(--space-4) + 60px);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.55rem 1rem;
    height: 46px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #ffffff;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    transition: background var(--transition), border-color var(--transition);
  }
  .lb-dl:hover {
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  @media (max-width: 600px) {
    .lb-dl-text {
      display: none;
    }
    .lb-dl {
      right: calc(var(--space-4) + 54px);
      padding: 0 0.85rem;
    }
  }

  .lb-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    transition: background var(--transition);
  }
  .lb-close:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .lb-nav {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
  }
  .lb-nav:hover {
    background: rgba(255, 255, 255, 0.22);
  }
  .lb-prev {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
  }
  .lb-next {
    position: absolute;
    right: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
  }
  @media (max-width: 600px) {
    .lb-prev,
    .lb-next {
      top: auto;
      bottom: var(--space-4);
      transform: none;
    }
    .lb-prev {
      left: var(--space-4);
    }
    .lb-next {
      right: var(--space-4);
    }
  }
</style>

<script>
  const tiles = Array.from(
    document.querySelectorAll<HTMLElement>(".tile"),
  );
  const data = tiles.map((t) => ({
    src: t.dataset.src || "",
    name: t.dataset.name || "",
    alt: t.dataset.alt || "",
  }));

  const lb = document.getElementById("lightbox") as HTMLElement | null;
  const lbImg = document.getElementById("lb-image") as HTMLImageElement | null;
  const lbDl = document.getElementById("lb-download") as HTMLAnchorElement | null;
  const closeBtn = document.querySelector<HTMLButtonElement>(".lb-close");
  const prevBtn = document.querySelector<HTMLButtonElement>(".lb-prev");
  const nextBtn = document.querySelector<HTMLButtonElement>(".lb-next");

  let current = 0;

  function open(idx: number) {
    if (!lb || !lbImg) return;
    current = idx;
    lbImg.src = data[idx].src;
    lbImg.alt = data[idx].alt;
    if (lbDl) {
      lbDl.href = data[idx].src;
      lbDl.setAttribute("download", data[idx].name);
    }
    lb.hidden = false;
    document.body.style.overflow = "hidden";
    // next frame so the transition can run
    requestAnimationFrame(() => lb.classList.add("is-open"));
  }

  function close() {
    if (!lb) return;
    lb.classList.remove("is-open");
    document.body.style.overflow = "";
    const onEnd = () => {
      lb.hidden = true;
      lb.removeEventListener("transitionend", onEnd);
    };
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      lb.hidden = true;
    } else {
      lb.addEventListener("transitionend", onEnd);
    }
  }

  function step(delta: number) {
    open((current + delta + data.length) % data.length);
  }

  tiles.forEach((tile, idx) => {
    tile.addEventListener("click", () => open(idx));
    tile.setAttribute("tabindex", "0");
    tile.setAttribute("role", "button");
    tile.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open(idx);
      }
    });
  });

  closeBtn?.addEventListener("click", close);
  prevBtn?.addEventListener("click", () => step(-1));
  nextBtn?.addEventListener("click", () => step(1));
  lb?.addEventListener("click", (e) => {
    if (e.target === lb) close();
  });
  window.addEventListener("keydown", (e) => {
    if (lb?.hidden) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") step(-1);
    if (e.key === "ArrowRight") step(1);
  });
</script>
