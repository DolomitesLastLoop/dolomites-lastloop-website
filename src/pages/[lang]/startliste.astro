---
import BaseLayout from "@layouts/BaseLayout.astro";
import { useTranslations, type Lang } from "@i18n/utils";
import {
  getPublicClient,
  MAX_PARTICIPANTS,
  type Participant,
} from "@lib/supabase";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

let participants: Participant[] = [];
let confirmedCount = 0;

try {
  // Least Privilege: öffentliche Seite liest mit dem Anon-Key aus der View
  // participants_public (nur unkritische Spalten, bereits auf confirmed/
  // waitlist gefiltert). Alias status→ticket_status, damit der Rendering-Code
  // unverändert bleibt.
  const supabase = getPublicClient();
  const { data } = await supabase
    .from("participants_public")
    .select(
      "id,vorname,nachname,nationalitaet,ticket_status:status,startnummer,created_at",
    )
    .order("startnummer", { ascending: true, nullsFirst: false })
    .order("created_at", { ascending: true });
  participants = (data as Participant[]) ?? [];
  confirmedCount = participants.filter((p) => p.ticket_status === "confirmed").length;
} catch {
  participants = [];
}

const statusLabel = (s: string) => {
  if (s === "confirmed") return t("startlist.status.confirmed");
  if (s === "waitlist") return t("startlist.status.waitlist");
  return t("startlist.status.pending");
};
const statusClass = (s: string) => {
  if (s === "confirmed") return "badge-confirmed";
  if (s === "waitlist") return "badge-waitlist";
  return "badge-pending";
};
---

<BaseLayout
  lang={lang}
  title={t("startlist.title")}
  description={t("meta.startlist")}
  breadcrumbs={[
    { name: t("nav.home"), url: `/${lang}` },
    { name: t("startlist.title"), url: `/${lang}/startliste` },
  ]}
>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Live</p>
      <h1>{t("startlist.title")}</h1>
      <p class="section-lead">
        {t("startlist.counter", { filled: confirmedCount, total: MAX_PARTICIPANTS })}
      </p>
      <div class="capacity" aria-hidden="true">
        <div
          class="capacity-bar"
          style={`width:${Math.min(100, (confirmedCount / MAX_PARTICIPANTS) * 100)}%`}
        ></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="search-wrap mb-5">
        <input
          type="search"
          id="startlist-search"
          placeholder={t("startlist.search")}
          aria-label={t("startlist.search")}
        />
      </div>

      {
        participants.length === 0 ? (
          <p class="text-dim">{t("startlist.empty")}</p>
        ) : (
          <div class="table-wrap">
            <table class="table" id="startlist-table">
              <thead>
                <tr>
                  <th>{t("startlist.col.number")}</th>
                  <th>{t("startlist.col.name")}</th>
                  <th>{t("startlist.col.nation")}</th>
                  <th>{t("startlist.col.status")}</th>
                </tr>
              </thead>
              <tbody>
                {participants.map((p, idx) => (
                  <tr data-name={`${p.vorname} ${p.nachname}`.toLowerCase()}>
                    <td>{p.startnummer ?? idx + 1}</td>
                    <td>
                      {p.vorname} {p.nachname}
                    </td>
                    <td>{p.nationalitaet ?? "—"}</td>
                    <td>
                      <span class={`badge ${statusClass(p.ticket_status)}`}>
                        {statusLabel(p.ticket_status)}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: var(--space-9) 0 var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .capacity {
    margin-top: var(--space-4);
    width: 100%;
    height: 8px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }
  .capacity-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover));
    transition: width 600ms var(--ease);
  }
  .search-wrap input {
    width: 100%;
    max-width: 420px;
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    font-size: 1rem;
  }
  .search-wrap input:focus {
    border-color: var(--color-accent);
    outline: none;
  }
  .table-wrap {
    overflow-x: auto;
  }
</style>

<script>
  const search = document.getElementById("startlist-search") as HTMLInputElement | null;
  search?.addEventListener("input", () => {
    const q = search.value.trim().toLowerCase();
    document
      .querySelectorAll<HTMLTableRowElement>("#startlist-table tbody tr")
      .forEach((row) => {
        const name = row.dataset.name || "";
        row.style.display = !q || name.includes(q) ? "" : "none";
      });
  });
</script>
