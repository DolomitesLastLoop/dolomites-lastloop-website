---
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Countdown from "@components/Countdown.astro";
import EmotionQuote from "@components/EmotionQuote.astro";
import AthletesEmotion from "@components/AthletesEmotion.astro";
import StorySplit from "@components/StorySplit.astro";
import LoopCircle from "@components/LoopCircle.astro";
import Marquee from "@components/Marquee.astro";
import FullBleedImage from "@components/FullBleedImage.astro";
import Testimonials from "@components/Testimonials.astro";
import Newsletter from "@components/Newsletter.astro";
import { pos } from "@lib/photos";
import { homePhoto } from "@lib/home-images";
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

export const prerender = false;

const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) {
  return Astro.redirect("/de", 302);
}
const t = useTranslations(lang);
---

<BaseLayout lang={lang} preloadImage="/images/hero-start.jpg">
  <Hero lang={lang} />

  <Countdown lang={lang} />

  <EmotionQuote
    lang={lang}
    left={homePhoto.portrait_exhausted}
    leftPos={pos.portrait}
    right={homePhoto.night_intense}
    rightPos={pos.portrait}
  />

  <section class="section" id="features">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">USP</span>
        <h2 class="reveal-left" data-delay="100">{t("home.features.title")}</h2>
      </div>

      <div class="grid grid-2 mt-6">
        <article class="card reveal" data-delay="100">
          <h3>{t("home.features.location.title")}</h3>
          <p>{t("home.features.location.text")}</p>
        </article>
        <article class="card reveal" data-delay="200">
          <h3>{t("home.features.format.title")}</h3>
          <p>{t("home.features.format.text")}</p>
        </article>
        <article class="card reveal" data-delay="300">
          <h3>{t("home.features.community.title")}</h3>
          <p>{t("home.features.community.text")}</p>
        </article>
        <article class="card reveal" data-delay="400">
          <h3>{t("home.features.limit.title")}</h3>
          <p>{t("home.features.limit.text")}</p>
        </article>
      </div>
    </div>
  </section>

  <div class="fade-zone" data-fade-zone aria-hidden="true"><span></span></div>

  <AthletesEmotion
    lang={lang}
    col1={{ src: homePhoto.night_focus, position: pos.portrait, alt: t("alt.athletes_night") }}
    col2={{ src: homePhoto.start_group, position: pos.group, alt: t("alt.athletes_start") }}
    col3={{ src: homePhoto.portrait_a, position: pos.portrait, alt: t("alt.athletes_portrait") }}
  />

  <LoopCircle label="2027" />

  <StorySplit
    lang={lang}
    photo={homePhoto.course_runner_c}
    alt={t("alt.story_course")}
    position={pos.upper}
  />

  <Marquee variant="primary" />

  <FullBleedImage
    lang={lang}
    src={homePhoto.day_running_2}
    alt={t("alt.fullbleed_day")}
    position={pos.landscape}
  />

  <div class="fade-zone" data-fade-zone aria-hidden="true"><span></span></div>

  <!-- Cinematic 2026 retrospective -->
  <section class="retro" aria-labelledby="retro-title">
    <div class="retro-bg" aria-hidden="true">
      <Image
        src={homePhoto.start_atmosphere_a}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        format="webp"
        quality={64}
        loading="lazy"
        decoding="async"
        style={`object-position:${pos.group}`}
      />
      <div class="retro-overlay"></div>
    </div>

    <div class="container retro-inner">
      <p class="eyebrow on-dark reveal">2026 · Toblach</p>
      <h2 id="retro-title" class="retro-title reveal reveal-left" data-delay="100">
        {t("home.archive.title")}
      </h2>
      <p class="retro-lead reveal" data-delay="200">
        {t("home.archive.first_edition")}
      </p>

      <div class="retro-stats reveal" data-delay="300">
        <div class="retro-stat">
          <span
            class="num"
            data-counter="101"
            data-duration="1500"
          >0</span>
          <span class="lbl">{t("home.archive.stat.starters")}</span>
        </div>
        <div class="retro-stat">
          <span
            class="num"
            data-counter="6.71"
            data-decimals="2"
            data-locale="de"
            data-duration="1500"
          >0</span>
          <span class="lbl">{t("home.archive.stat.loop")}</span>
        </div>
        <div class="retro-stat">
          <span class="num">
            <span
              data-counter="38"
              data-duration="1500"
              data-locale="de"
              data-plus
            >0</span><span class="plus" data-plus-target>+</span>
          </span>
          <span class="lbl">{t("home.archive.stat.hours")}</span>
        </div>
      </div>

      <div class="retro-cta reveal" data-delay="400">
        <a class="btn btn-primary btn-arrow" href={localizePath("/galerie", lang)}>
          {t("home.archive.gallery")}
        </a>
        <a class="btn btn-on-dark btn-arrow" href={localizePath("/ergebnisse", lang)}>
          {t("home.archive.link")}
        </a>
      </div>
    </div>

    <span class="retro-credit">© Harald Wisthaler</span>
  </section>

  <Testimonials lang={lang} />

  <Newsletter lang={lang} />
</BaseLayout>

<style>
  .retro {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--space-10) 0;
    color: #ffffff;
  }
  .retro-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .retro-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .retro-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20, 35, 55, 0.6), rgba(20, 35, 55, 0.78)),
      radial-gradient(
        ellipse at center,
        rgba(20, 35, 55, 0.2),
        rgba(20, 35, 55, 0.7)
      );
  }
  .retro-inner {
    position: relative;
    text-align: center;
  }
  .eyebrow.on-dark {
    color: #ffffff;
  }
  .eyebrow.on-dark::before {
    background: rgba(255, 255, 255, 0.6);
  }
  .retro-title {
    color: #ffffff;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
    margin-bottom: var(--space-4);
  }
  .retro-lead {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.2rem;
    max-width: 50ch;
    margin: 0 auto var(--space-7);
  }
  .retro-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    max-width: 720px;
    margin: 0 auto var(--space-7);
  }
  @media (max-width: 600px) {
    .retro-stats {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
  .retro-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: transform var(--transition);
  }
  .retro-stat:hover {
    transform: scale(1.04);
  }
  .retro-stat .num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    letter-spacing: 0.04em;
    color: #ffffff;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.5);
  }
  .retro-stat .lbl {
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }
  .retro-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  .retro-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    pointer-events: none;
  }
</style>
