---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Newsletter from "@components/Newsletter.astro";
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

export const prerender = false;

const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) {
  return Astro.redirect("/de", 302);
}
const t = useTranslations(lang);
---

<BaseLayout lang={lang}>
  <Hero lang={lang} />

  <section class="section" id="features">
    <div class="container">
      <p class="eyebrow reveal">USP</p>
      <h2 class="reveal">{t("home.features.title")}</h2>
      <div class="grid grid-2 mt-6">
        <article class="card reveal">
          <h3>{t("home.features.location.title")}</h3>
          <p>{t("home.features.location.text")}</p>
        </article>
        <article class="card reveal">
          <h3>{t("home.features.format.title")}</h3>
          <p>{t("home.features.format.text")}</p>
        </article>
        <article class="card reveal">
          <h3>{t("home.features.community.title")}</h3>
          <p>{t("home.features.community.text")}</p>
        </article>
        <article class="card reveal">
          <h3>{t("home.features.limit.title")}</h3>
          <p>{t("home.features.limit.text")}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="visual-band">
    <div class="visual-band-img reveal" aria-hidden="true">
      <img
        src="/images/day-running-2.jpg"
        alt=""
        loading="lazy"
      />
    </div>
    <div class="visual-band-caption">
      <p>© Wisthaler Photography</p>
    </div>
  </section>

  <section class="section section-alt archive-teaser">
    <div class="container archive-inner">
      <div class="archive-text reveal">
        <p class="eyebrow">{t("home.archive.title")}</p>
        <h2>2026</h2>
        <p class="text-muted">{t("home.archive.first_edition")}</p>
        <div class="archive-actions mt-5">
          <a class="btn btn-primary" href={localizePath("/galerie", lang)}>
            {t("nav.gallery")} →
          </a>
          <a class="btn btn-ghost" href={localizePath("/ergebnisse", lang)}>
            {t("home.archive.link")}
          </a>
        </div>
      </div>
      <div class="archive-stats reveal" aria-hidden="true">
        <div>
          <span class="stat-num">6,71</span>
          <span class="stat-label">km / Loop</span>
        </div>
        <div>
          <span class="stat-num">150</span>
          <span class="stat-label">Starter</span>
        </div>
        <div>
          <span class="stat-num">∞</span>
          <span class="stat-label">Stunden</span>
        </div>
      </div>
    </div>
  </section>

  <Newsletter lang={lang} />
</BaseLayout>

<style>
  .visual-band {
    position: relative;
    margin: var(--space-7) 0 0;
  }
  .visual-band-img {
    position: relative;
    width: 100%;
    height: clamp(280px, 50vh, 520px);
    overflow: hidden;
  }
  .visual-band-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 800ms var(--ease);
  }
  .visual-band:hover .visual-band-img img {
    transform: scale(1.02);
  }
  .visual-band-caption {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }

  .archive-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .archive-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .archive-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    text-align: center;
  }
  .archive-stats > div {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    box-shadow: var(--shadow-card);
  }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: var(--color-accent);
    line-height: 1;
  }
  .stat-label {
    display: block;
    margin-top: var(--space-2);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  @media (max-width: 800px) {
    .archive-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
