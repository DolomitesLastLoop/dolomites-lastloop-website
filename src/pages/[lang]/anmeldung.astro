---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import RegistrationFlow from "@components/RegistrationFlow.astro";
import { photo, pos } from "@lib/photos";
import { isRegistrationEnabled } from "@lib/registration";
import { getAdminClient } from "@lib/supabase";
import { useTranslations, type Lang } from "@i18n/utils";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

// Feature-Flag: solange nicht 'true', ist die öffentliche Anmeldung deaktiviert.
// Zentrale, fail-safe Auswertung in @lib/registration — dieselbe Quelle gatet auch
// den Zahlungs-Endpoint (/api/checkout).
const registrationEnabled = isRegistrationEnabled();

// Auch bei deaktiviertem Flag muss ein bereits bezahlter Teilnehmer Schritt 3
// (Attest) erreichen: nach Stripe-Erfolg (?status=success) oder über den
// Magic-Link aus der Bestätigungs-Email (?id=…&token=…). Dann wird NUR der
// Attest-Schritt gezeigt (attestOnly) — nicht das ganze Formular, damit das
// Flag-Gating der eigentlichen Anmeldung erhalten bleibt.
const params = new URL(Astro.request.url).searchParams;
const isPostPaymentReturn =
  params.get("status") === "success" ||
  Boolean(params.get("id") && params.get("token"));

// Direkter Post-Payment-Return (?status=success&session_id=…): Identität
// serverseitig über die gespeicherte stripe_session_id auflösen, damit der Nutzer
// NIE das rohe "Registration ID"-Feld sieht. Der attest_token wird erst vom
// Webhook nach der Zahlung erzeugt → drei mögliche Zustände (siehe unten). Der
// Magic-Link-Pfad (?id=…&token=…) läuft weiter clientseitig und wird hier bewusst
// übersprungen, damit er unverändert bleibt.
const sessionId = (params.get("session_id") ?? "").trim();
const isMagicLink = Boolean(params.get("id") && params.get("token"));
let prefillId: string | undefined;
let prefillToken: string | undefined;
let awaitingPayment = false;
let attestFallback = false;

if (params.get("status") === "success" && !isMagicLink) {
  if (/^cs_[A-Za-z0-9_]+$/.test(sessionId)) {
    try {
      const supabase = getAdminClient();
      const { data } = await supabase
        .from("participants")
        .select("id, attest_token")
        .eq("stripe_session_id", sessionId)
        .maybeSingle();
      if (data?.id && data.attest_token) {
        // Zustand "prefill": Teilnehmer + Token vorhanden → direkt vorbefüllen.
        prefillId = data.id as string;
        prefillToken = data.attest_token as string;
      } else if (data?.id) {
        // Zustand "awaiting": Teilnehmer da, Token noch nicht (Webhook-Race) →
        // Wartemeldung + Poll/Reload. Erwarteter Fall, daher NICHT geloggt.
        awaitingPayment = true;
      } else {
        // Zustand "notFound": keine Zeile zu dieser session_id → echter Sonderfall
        // (unbekannte/manipulierte session_id). Still serverseitig loggen.
        attestFallback = true;
        console.warn(
          `[anmeldung] Post-Payment-Return ohne Teilnehmer-Treffer für session_id=${sessionId}`,
        );
      }
    } catch (err) {
      // DB-Fehler: nicht blockieren, sondern Fallback-Meldung zeigen.
      attestFallback = true;
      console.warn("[anmeldung] Lookup der stripe_session_id fehlgeschlagen:", err);
    }
  } else {
    // status=success ohne verwertbare session_id → Identität fehlt (manuelle URL,
    // abgeschnittener Redirect). Klare Email-Link-Meldung statt rohem ID-Feld.
    attestFallback = true;
    console.warn("[anmeldung] Post-Payment-Return ohne verwertbare session_id");
  }
}
---

<BaseLayout
  lang={lang}
  title={t("signup.title")}
  description={t("meta.signup")}
  breadcrumbs={[
    { name: t("nav.home"), url: `/${lang}` },
    { name: t("signup.title"), url: `/${lang}/anmeldung` },
  ]}
>
  {
    registrationEnabled ? (
      <RegistrationFlow
        lang={lang}
        basePath="anmeldung"
        prefillId={prefillId}
        prefillToken={prefillToken}
        awaitingPayment={awaitingPayment}
        attestFallback={attestFallback}
      />
    ) : isPostPaymentReturn ? (
      <RegistrationFlow
        lang={lang}
        basePath="anmeldung"
        attestOnly
        prefillId={prefillId}
        prefillToken={prefillToken}
        awaitingPayment={awaitingPayment}
        attestFallback={attestFallback}
      />
    ) : (
      <>
        <PageHero
          bg={photo.emotion_smile}
          position={pos.faceTight}
          eyebrow={t("signup.eyebrow")}
          title={t("signup.hero_title")}
          subtitle={t("signup.hero_subtitle")}
        />
        <section class="section">
          <div class="container-narrow text-center soon">
            <h2>{t("signup.soon.title")}</h2>
            <p>{t("signup.soon.text")}</p>
          </div>
        </section>
      </>
    )
  }
</BaseLayout>

<style>
  .soon {
    padding: var(--space-8) 0;
  }
  .soon h2 {
    margin-bottom: var(--space-4);
  }
  .soon p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
