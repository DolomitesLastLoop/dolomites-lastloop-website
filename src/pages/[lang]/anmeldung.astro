---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { photo, pos } from "@lib/photos";
import { useTranslations, type Lang } from "@i18n/utils";
import { getAdminClient, MAX_PARTICIPANTS } from "@lib/supabase";
import { TICKET_TIERS } from "@lib/stripe";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

const url = new URL(Astro.request.url);
const sessionStatus = url.searchParams.get("status");

let isFull = false;
let slotsTaken = 0;
try {
  const supabase = getAdminClient();
  const { count } = await supabase
    .from("participants")
    .select("id", { count: "exact", head: true })
    .in("ticket_status", ["confirmed", "pending"]);
  slotsTaken = count ?? 0;
  isFull = slotsTaken >= MAX_PARTICIPANTS;
} catch {
  isFull = false;
}
const slotsLeft = Math.max(0, MAX_PARTICIPANTS - slotsTaken);

const today = new Date();
const minDate = new Date(today.getFullYear() - 100, today.getMonth(), today.getDate());
const maxDate = new Date(today.getFullYear() - 18, today.getMonth(), today.getDate());
const minISO = minDate.toISOString().slice(0, 10);
const maxISO = maxDate.toISOString().slice(0, 10);
---

<BaseLayout lang={lang} title={t("signup.title")}>
  <PageHero
    bg={photo.emotion_smile}
    position={pos.faceTight}
    eyebrow={t("signup.eyebrow")}
    title={t("signup.hero_title")}
    subtitle={t("signup.hero_subtitle")}
  />

  <div class="strip">
    <img
      src={photo.course_anmeldung}
      alt=""
      loading="lazy"
      style={`object-position:${pos.landscape}`}
    />
  </div>

  <div class="badges container">
    <span class="badge-pill reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 21l4-10 4 6 4-9 6 13" />
      </svg>
      {t("signup.badge.location")}
    </span>
    <span class="badge-pill reveal" data-delay="100">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="5" width="18" height="16" rx="2" />
        <path d="M3 9h18" />
        <path d="M8 3v4M16 3v4" />
      </svg>
      {t("signup.badge.date")}
    </span>
    <span class="badge-pill reveal" data-delay="200">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="9" r="3" />
        <path d="M3 20a6 6 0 0 1 12 0" />
        <circle cx="17" cy="11" r="2.5" />
        <path d="M13 20a4 4 0 0 1 8 0" />
      </svg>
      {t("signup.badge.slots")}
    </span>
  </div>

  <section class="section signup-section">
    <div class="container signup-grid">
      <div class="signup-main">
      {
        sessionStatus === "success" && (
          <div class="alert alert-success">
            <strong>✓</strong> Zahlung erfolgreich. Bitte ärztliches Attest hochladen.
          </div>
        )
      }
      {
        sessionStatus === "cancelled" && (
          <div class="alert alert-error">
            Zahlung abgebrochen. Du kannst es jederzeit erneut versuchen.
          </div>
        )
      }

      {
        isFull ? (
          <div class="card text-center">
            <h2>{t("signup.full.title")}</h2>
            <p>{t("signup.full.text")}</p>
            <form class="waitlist-form mt-6" data-waitlist novalidate>
              <div class="field">
                <label for="wl-name">{t("contact.form.name")}</label>
                <input type="text" id="wl-name" name="name" required />
              </div>
              <div class="field">
                <label for="wl-email">{t("contact.form.email")}</label>
                <input type="email" id="wl-email" name="email" required />
              </div>
              <button class="btn btn-primary btn-block" type="submit">
                {t("signup.full.cta")}
              </button>
              <p class="status status-success mt-4" data-wl-success hidden>
                {t("home.newsletter.success")}
              </p>
              <p class="status status-error mt-4" data-wl-error hidden>
                {t("home.newsletter.error")}
              </p>
            </form>
          </div>
        ) : (
          <>
            <div class="steps" role="tablist" aria-label="Sign-up steps">
              <div class="step active" data-step-indicator="1">
                <span class="step-num">01</span>
                <span class="step-label">{t("signup.step1.title")}</span>
              </div>
              <div class="step" data-step-indicator="2">
                <span class="step-num">02</span>
                <span class="step-label">{t("signup.step2.title")}</span>
              </div>
              <div class="step" data-step-indicator="3">
                <span class="step-num">03</span>
                <span class="step-label">{t("signup.step3.title")}</span>
              </div>
            </div>

            <form class="signup-form" id="signup-form" novalidate>
              {/* Step 1 */}
              <fieldset class="step-panel" data-panel="1">
                <legend class="sr-only">{t("signup.step1.title")}</legend>

                <div class="field-row">
                  <div class="field">
                    <label for="vorname">{t("signup.field.firstname")}</label>
                    <input type="text" id="vorname" name="vorname" required />
                  </div>
                  <div class="field">
                    <label for="nachname">{t("signup.field.lastname")}</label>
                    <input type="text" id="nachname" name="nachname" required />
                  </div>
                </div>

                <div class="field">
                  <label for="email">{t("signup.field.email")}</label>
                  <input type="email" id="email" name="email" required />
                </div>

                <div class="field-row">
                  <div class="field">
                    <label for="geburtsdatum">{t("signup.field.birthdate")}</label>
                    <input
                      type="date"
                      id="geburtsdatum"
                      name="geburtsdatum"
                      min={minISO}
                      max={maxISO}
                      required
                    />
                    <span class="hint">{t("signup.field.age_error")}</span>
                  </div>
                  <div class="field">
                    <label for="nationalitaet">{t("signup.field.nationality")}</label>
                    <input
                      type="text"
                      id="nationalitaet"
                      name="nationalitaet"
                      placeholder="IT, DE, AT, CH…"
                    />
                  </div>
                </div>

                <div class="field-row">
                  <div class="field">
                    <label for="notfallkontakt_name">
                      {t("signup.field.emergency_name")}
                    </label>
                    <input
                      type="text"
                      id="notfallkontakt_name"
                      name="notfallkontakt_name"
                      required
                    />
                  </div>
                  <div class="field">
                    <label for="notfallkontakt_tel">
                      {t("signup.field.emergency_phone")}
                    </label>
                    <input
                      type="tel"
                      id="notfallkontakt_tel"
                      name="notfallkontakt_tel"
                      required
                    />
                  </div>
                </div>

                <p class="status status-error" data-step1-error hidden></p>

                <div class="flex-between mt-6">
                  <span class="text-dim">{t("signup.step")} 1 / 3</span>
                  <button class="btn btn-primary" type="button" data-next="2">
                    {t("signup.continue")} →
                  </button>
                </div>
              </fieldset>

              {/* Step 2 */}
              <fieldset class="step-panel" data-panel="2" hidden>
                <legend class="sr-only">{t("signup.step2.title")}</legend>

                <div class="tickets">
                  {TICKET_TIERS.map((tier) => (
                    <label class="ticket-option">
                      <input
                        type="radio"
                        name="tier"
                        value={tier.id}
                        checked={tier.id === "early_bird"}
                      />
                      <span class="ticket-card">
                        <span class="ticket-name">{t(tier.labelKey)}</span>
                        <span class="ticket-price">{tier.priceLabel}</span>
                        <span class="ticket-incl text-dim">
                          {t("signup.ticket.included")}
                        </span>
                      </span>
                    </label>
                  ))}
                </div>

                <p class="status status-error" data-step2-error hidden></p>

                <div class="flex-between mt-6">
                  <button class="btn btn-ghost" type="button" data-prev="1">
                    ← {t("signup.back")}
                  </button>
                  <button class="btn btn-primary" type="button" data-checkout>
                    {t("signup.ticket.checkout")} →
                  </button>
                </div>
              </fieldset>

              {/* Step 3 */}
              <fieldset class="step-panel" data-panel="3" hidden>
                <legend class="sr-only">{t("signup.step3.title")}</legend>

                <h2>{t("signup.attest.title")}</h2>
                <p class="text-muted mb-5">{t("signup.attest.hint")}</p>

                <div class="field">
                  <label for="participant-id-input">Registration ID</label>
                  <input
                    type="text"
                    id="participant-id-input"
                    name="participant_id"
                    placeholder="aus Bestätigungs-Email"
                  />
                </div>

                <div class="field">
                  <label for="attest-file">PDF (max 5 MB)</label>
                  <input
                    type="file"
                    id="attest-file"
                    name="attest"
                    accept="application/pdf"
                  />
                </div>

                <button class="btn btn-primary" type="button" data-upload-attest>
                  {t("signup.attest.upload")}
                </button>
                <a class="btn btn-ghost ml-3" href="/">
                  {t("signup.attest.skip")}
                </a>

                <p class="status status-success mt-4" data-attest-success hidden>
                  {t("signup.attest.success")}
                </p>
                <p class="status status-error mt-4" data-attest-error hidden></p>
              </fieldset>
            </form>
          </>
        )
      }
      </div>

      <aside class="signup-side">
        <figure class="side-photo reveal reveal-scale">
          <img
            src={photo.portrait_b}
            alt=""
            loading="lazy"
            style={`object-position:${pos.portrait}`}
          />
        </figure>

        <ul class="side-facts">
          <li class="reveal" data-delay="100">{t("signup.side.fact1")}</li>
          <li class="reveal" data-delay="200">{t("signup.side.fact2")}</li>
          <li class="reveal" data-delay="300">{t("signup.side.fact3")}</li>
        </ul>

        <div class="slots-card reveal" data-delay="400">
          <span class="slots-num">{slotsLeft}</span>
          <span class="slots-lbl">
            {t("signup.side.slots_left", { n: slotsLeft })}
          </span>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .strip {
    width: 100%;
    height: 180px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }
  .strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .badges {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    padding: var(--space-6) var(--space-5) 0;
  }
  .badge-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    box-shadow: var(--shadow-card);
  }
  .badge-pill svg {
    width: 18px;
    height: 18px;
    color: var(--color-primary);
  }

  .signup-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--space-7);
    align-items: start;
  }
  @media (max-width: 1000px) {
    .signup-grid {
      grid-template-columns: 1fr;
    }
  }

  .signup-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-5));
  }
  @media (max-width: 1000px) {
    .signup-side {
      position: static;
    }
  }
  .side-photo {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
  }
  .side-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .side-facts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .side-facts li {
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.95rem;
  }
  .side-facts li:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .slots-card {
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius);
    padding: var(--space-5);
    text-align: center;
    box-shadow: var(--shadow-card);
  }
  .slots-num {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
    letter-spacing: 0.05em;
  }
  .slots-lbl {
    display: block;
    margin-top: var(--space-2);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.92;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .step {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    opacity: 0.55;
    transition:
      opacity var(--transition),
      border-color var(--transition),
      background var(--transition),
      color var(--transition),
      box-shadow var(--transition);
    position: relative;
  }
  .step.active {
    opacity: 1;
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #ffffff;
    box-shadow: 0 6px 18px rgba(45, 74, 107, 0.18);
  }
  .step.active .step-label {
    color: rgba(255, 255, 255, 0.85);
  }
  .step-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-primary);
    transition: color var(--transition);
  }
  .step.active .step-num {
    color: #ffffff;
  }
  .step-label {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .signup-form fieldset {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    background: var(--color-card);
  }

  .tickets {
    display: grid;
    gap: var(--space-4);
  }
  .ticket-option {
    display: block;
    cursor: pointer;
  }
  .ticket-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .ticket-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-2) var(--space-4);
    align-items: center;
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color var(--transition), background var(--transition);
  }
  .ticket-option input:checked + .ticket-card {
    border-color: var(--color-accent);
    background: var(--color-accent-dim);
  }
  .ticket-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .ticket-price {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-accent);
  }
  .ticket-incl {
    grid-column: 1 / -1;
    font-size: 0.85rem;
  }

  .ml-3 {
    margin-left: var(--space-3);
  }
  .status-success {
    color: var(--color-success);
  }
  .status-error {
    color: var(--color-error);
  }
</style>

<script>
  function showStep(n: number) {
    document.querySelectorAll<HTMLElement>("[data-panel]").forEach((el) => {
      el.hidden = el.dataset.panel !== String(n);
    });
    document.querySelectorAll<HTMLElement>("[data-step-indicator]").forEach((el) => {
      const idx = Number(el.dataset.stepIndicator);
      el.classList.toggle("active", idx <= n);
    });
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function showError(target: string, message: string) {
    const el = document.querySelector<HTMLElement>(target);
    if (!el) return;
    el.textContent = message;
    el.hidden = false;
  }
  function clearError(target: string) {
    const el = document.querySelector<HTMLElement>(target);
    if (!el) return;
    el.textContent = "";
    el.hidden = true;
  }

  function validateStep1(): string | null {
    const form = document.getElementById("signup-form") as HTMLFormElement | null;
    if (!form) return "Formular nicht gefunden";
    const data = new FormData(form);
    const required = [
      "vorname",
      "nachname",
      "email",
      "geburtsdatum",
      "notfallkontakt_name",
      "notfallkontakt_tel",
    ];
    for (const key of required) {
      const v = String(data.get(key) || "").trim();
      if (!v) return "Bitte alle Pflichtfelder ausfüllen.";
    }
    const email = String(data.get("email"));
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      return "Bitte gültige Email-Adresse angeben.";
    }
    const birth = new Date(String(data.get("geburtsdatum")));
    const today = new Date();
    const age =
      today.getFullYear() -
      birth.getFullYear() -
      (today < new Date(today.getFullYear(), birth.getMonth(), birth.getDate()) ? 1 : 0);
    if (!Number.isFinite(age) || age < 18) {
      return "Du musst mindestens 18 Jahre alt sein.";
    }
    return null;
  }

  document.querySelectorAll<HTMLButtonElement>("[data-next]").forEach((btn) => {
    btn.addEventListener("click", () => {
      clearError("[data-step1-error]");
      const err = validateStep1();
      if (err) {
        showError("[data-step1-error]", err);
        return;
      }
      showStep(Number(btn.dataset.next));
    });
  });
  document.querySelectorAll<HTMLButtonElement>("[data-prev]").forEach((btn) => {
    btn.addEventListener("click", () => showStep(Number(btn.dataset.prev)));
  });

  document
    .querySelector<HTMLButtonElement>("[data-checkout]")
    ?.addEventListener("click", async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      btn.disabled = true;
      clearError("[data-step2-error]");
      try {
        const form = document.getElementById("signup-form") as HTMLFormElement;
        const data = new FormData(form);
        const payload = Object.fromEntries(data.entries());
        const res = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const json = await res.json();
        if (!res.ok || !json.url) {
          showError(
            "[data-step2-error]",
            json.error || "Zahlung konnte nicht gestartet werden.",
          );
          btn.disabled = false;
          return;
        }
        window.location.href = json.url;
      } catch (err) {
        showError("[data-step2-error]", "Netzwerkfehler. Bitte erneut versuchen.");
        btn.disabled = false;
      }
    });

  document
    .querySelector<HTMLButtonElement>("[data-upload-attest]")
    ?.addEventListener("click", async () => {
      const idEl = document.getElementById(
        "participant-id-input",
      ) as HTMLInputElement | null;
      const fileEl = document.getElementById("attest-file") as HTMLInputElement | null;
      clearError("[data-attest-error]");
      if (!idEl?.value || !fileEl?.files?.[0]) {
        showError("[data-attest-error]", "Bitte ID und PDF angeben.");
        return;
      }
      const file = fileEl.files[0];
      if (file.size > 5 * 1024 * 1024) {
        showError("[data-attest-error]", "Datei ist zu groß (max 5 MB).");
        return;
      }
      const fd = new FormData();
      fd.append("participant_id", idEl.value.trim());
      fd.append("file", file);
      try {
        const res = await fetch("/api/upload-attest", { method: "POST", body: fd });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || "upload failed");
        const ok = document.querySelector<HTMLElement>("[data-attest-success]");
        if (ok) ok.hidden = false;
      } catch (err: any) {
        showError("[data-attest-error]", err?.message || "Upload fehlgeschlagen.");
      }
    });

  // Waitlist
  document
    .querySelector<HTMLFormElement>("[data-waitlist]")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.currentTarget as HTMLFormElement;
      const ok = document.querySelector<HTMLElement>("[data-wl-success]");
      const err = document.querySelector<HTMLElement>("[data-wl-error]");
      if (ok) ok.hidden = true;
      if (err) err.hidden = true;
      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/waitlist", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error("fail");
        form.reset();
        if (ok) ok.hidden = false;
      } catch {
        if (err) err.hidden = false;
      }
    });

  // Auto-step to attest if URL has status=success
  const params = new URLSearchParams(window.location.search);
  if (params.get("status") === "success") {
    showStep(3);
  }
</script>
