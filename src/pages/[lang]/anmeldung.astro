---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import RegistrationFlow from "@components/RegistrationFlow.astro";
import { photo, pos } from "@lib/photos";
import { isRegistrationEnabled } from "@lib/registration";
import { useTranslations, type Lang } from "@i18n/utils";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

// Feature-Flag: solange nicht 'true', ist die öffentliche Anmeldung deaktiviert.
// Zentrale, fail-safe Auswertung in @lib/registration — dieselbe Quelle gatet auch
// den Zahlungs-Endpoint (/api/checkout).
const registrationEnabled = isRegistrationEnabled();

// Auch bei deaktiviertem Flag muss ein bereits bezahlter Teilnehmer Schritt 3
// (Attest) erreichen: nach Stripe-Erfolg (?status=success) oder über den
// Magic-Link aus der Bestätigungs-Email (?id=…&token=…). Dann wird NUR der
// Attest-Schritt gezeigt (attestOnly) — nicht das ganze Formular, damit das
// Flag-Gating der eigentlichen Anmeldung erhalten bleibt.
const params = new URL(Astro.request.url).searchParams;
const isPostPaymentReturn =
  params.get("status") === "success" ||
  Boolean(params.get("id") && params.get("token"));
---

<BaseLayout
  lang={lang}
  title={t("signup.title")}
  description={t("meta.signup")}
  breadcrumbs={[
    { name: t("nav.home"), url: `/${lang}` },
    { name: t("signup.title"), url: `/${lang}/anmeldung` },
  ]}
>
  {
    registrationEnabled ? (
      <RegistrationFlow lang={lang} basePath="anmeldung" />
    ) : isPostPaymentReturn ? (
      <RegistrationFlow lang={lang} basePath="anmeldung" attestOnly />
    ) : (
      <>
        <PageHero
          bg={photo.emotion_smile}
          position={pos.faceTight}
          eyebrow={t("signup.eyebrow")}
          title={t("signup.hero_title")}
          subtitle={t("signup.hero_subtitle")}
        />
        <section class="section">
          <div class="container-narrow text-center soon">
            <h2>{t("signup.soon.title")}</h2>
            <p>{t("signup.soon.text")}</p>
          </div>
        </section>
      </>
    )
  }
</BaseLayout>

<style>
  .soon {
    padding: var(--space-8) 0;
  }
  .soon h2 {
    margin-bottom: var(--space-4);
  }
  .soon p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
