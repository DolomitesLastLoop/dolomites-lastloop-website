---
import BaseLayout from "@layouts/BaseLayout.astro";
import { useTranslations, type Lang } from "@i18n/utils";
import { legal, type LegalSlug } from "@i18n/legal";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
const slug = Astro.params.legal as string | undefined;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);

const validSlugs = new Set<LegalSlug>([
  "impressum",
  "datenschutz",
  "agb",
  "barrierefreiheit",
  "rueckerstattung",
  "haftungsausschluss",
]);

if (!slug || !validSlugs.has(slug as LegalSlug)) {
  return new Response("Not found", { status: 404 });
}

const t = useTranslations(lang);

const titleMap: Record<string, string> = {
  impressum: t("footer.imprint"),
  datenschutz: t("footer.privacy"),
  agb: t("footer.terms"),
  barrierefreiheit: t("footer.accessibility"),
  rueckerstattung: t("footer.refund"),
  haftungsausschluss: t("footer.liability"),
};
const title = titleMap[slug] ?? slug;
const page = legal[lang][slug as LegalSlug];
---

<BaseLayout lang={lang} title={title}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1>{title}</h1>
      {page.updated && <p class="updated">{page.updated}</p>}
    </div>
  </section>

  <section class="section">
    <div class="container-narrow legal">
      {page.intro && <p class="intro">{page.intro}</p>}

      {
        page.sections.map((section) => (
          <div class="legal-section">
            <h2 id={section.id}>{section.heading}</h2>
            {section.blocks.map((block) => {
              if (block.type === "h") return <h3>{block.text}</h3>;
              if (block.type === "note") return <p class="note">{block.text}</p>;
              if (block.type === "list")
                return (
                  <ul>
                    {block.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                );
              return <p>{block.text}</p>;
            })}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: var(--space-9) 0 var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .updated {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .legal .intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: var(--space-7);
  }
  .legal-section {
    margin-bottom: var(--space-7);
  }
  .legal-section h2 {
    font-size: 1.4rem;
    margin-bottom: var(--space-4);
  }
  .legal-section h3 {
    font-size: 1.1rem;
    margin: var(--space-5) 0 var(--space-3);
  }
  .legal-section p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }
  .legal-section ul {
    margin: 0 0 var(--space-4);
    padding-left: var(--space-5);
    color: var(--color-text-muted);
  }
  .legal-section li {
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }
  .legal-section .note {
    border-left: 3px solid var(--color-primary);
    background: var(--color-accent-dim);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius);
    color: var(--color-text);
  }
</style>
