---
import BaseLayout from "@layouts/BaseLayout.astro";
import { useTranslations, localizePath, type Lang } from "@i18n/utils";
import { getAdminClient, type RaceResult } from "@lib/supabase";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);

let results: RaceResult[] = [];
try {
  const supabase = getAdminClient();
  const { data } = await supabase
    .from("results")
    .select("*")
    .order("year", { ascending: false })
    .order("place", { ascending: true });
  results = (data as RaceResult[]) ?? [];
} catch {
  results = [];
}

const grouped = results.reduce<Record<number, RaceResult[]>>((acc, r) => {
  (acc[r.year] ??= []).push(r);
  return acc;
}, {});
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);
const hasYears = years.length > 0;
---

<BaseLayout lang={lang} title={t("results.title")}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Archive</p>
      <h1>{t("results.title")}</h1>
      <p class="section-lead">{t("results.intro")}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        !hasYears && (
          <article class="card">
            <h2>{t("results.year.2026")}</h2>
            <p class="text-muted">{t("results.placeholder")}</p>
            <a class="btn btn-primary mt-5" href={localizePath("/galerie", lang)}>
              {t("results.gallery_link")}
            </a>
          </article>
        )
      }

      {
        hasYears && (
          <p class="reveal mb-6">
            <a class="btn btn-ghost" href={localizePath("/galerie", lang)}>
              {t("results.gallery_link")}
            </a>
          </p>
        )
      }

      {
        years.map((year) => (
          <article class="year-block mb-6">
            <h2>{year}</h2>
            <div class="table-wrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>{t("results.col.place")}</th>
                    <th>{t("results.col.name")}</th>
                    <th>{t("results.col.nation")}</th>
                    <th>{t("results.col.loops")}</th>
                  </tr>
                </thead>
                <tbody>
                  {grouped[year].map((r) => (
                    <tr>
                      <td>{r.place}</td>
                      <td>{r.name}</td>
                      <td>{r.nationalitaet ?? "—"}</td>
                      <td>{r.runden}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: var(--space-9) 0 var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .table-wrap {
    overflow-x: auto;
  }
</style>
