---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { photo, pos } from "@lib/photos";
import { useTranslations, type Lang } from "@i18n/utils";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t("contact.title")}>
  <PageHero
    bg={photo.start_atmosphere_b}
    position={pos.group}
    eyebrow={t("contact.eyebrow")}
    title={t("contact.title")}
    subtitle={t("contact.subtitle")}
  />

  <section class="section">
    <div class="container contact-grid">
      <form class="card reveal" data-contact novalidate>
        <h2>{t("contact.form.title")}</h2>

        <div class="field">
          <label for="c-name">{t("contact.form.name")}</label>
          <input type="text" id="c-name" name="name" required />
        </div>
        <div class="field">
          <label for="c-email">{t("contact.form.email")}</label>
          <input type="email" id="c-email" name="email" required />
        </div>
        <div class="field">
          <label for="c-message">{t("contact.form.message")}</label>
          <textarea id="c-message" name="message" required></textarea>
        </div>

        <button class="btn btn-primary btn-block btn-arrow" type="submit">
          {t("contact.form.submit")}
        </button>

        <p class="status status-success mt-4" data-c-success hidden>
          {t("contact.form.success")}
        </p>
        <p class="status status-error mt-4" data-c-error hidden>
          {t("contact.form.error")}
        </p>
      </form>

      <aside class="info reveal" data-delay="100">
        <figure class="info-photo reveal-scale">
          <img
            src={photo.hero_start}
            alt=""
            loading="lazy"
            style="object-position:center center"
          />
        </figure>

        <div class="info-list mt-5">
          <div class="info-item">
            <span class="info-label">{t("contact.email")}</span>
            <a href="mailto:dolomiteslastloop@gmail.com">
              dolomiteslastloop@gmail.com
            </a>
          </div>
          <div class="info-item">
            <span class="info-label">{t("contact.org")}</span>
            <span>{t("contact.org.value")}</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t("contact.location")}</span>
            <span>{t("contact.location.value")}</span>
          </div>
        </div>

        <div class="map mt-5">
          <iframe
            src="https://www.google.com/maps?q=Seeweg+16,+39034+Toblach+BZ,+Italy&output=embed"
            title={t("contact.location.value")}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
          <a
            class="map-link"
            href="https://www.google.com/maps?q=Seeweg+16,+39034+Toblach+BZ,+Italy"
            target="_blank"
            rel="noopener"
          >
            {t("contact.location.value")} →
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .contact-grid > form,
  .contact-grid > .info {
    width: 100%;
    align-self: start;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Match the card's internal top padding so the photo aligns with the
     "SCHREIB UNS" heading inside the card. */
  .info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-6);
  }

  .info-photo {
    margin: 0;
    height: 220px;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
  }
  .info-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .info > .info-list,
  .info > .map {
    margin-top: 0;
  }
  .info-list {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0 var(--space-4);
  }
  .info-item {
    padding: var(--space-3) 0;
  }
  .map iframe {
    height: 180px;
  }

  .info-item {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .info-item:last-of-type {
    border-bottom: none;
  }
  .info-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-1);
  }

  .map {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-card);
  }
  .map iframe {
    width: 100%;
    height: 280px;
    border: none;
    display: block;
  }
  .map-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: 0.85rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-primary);
  }

  .status-success {
    color: var(--color-success);
  }
  .status-error {
    color: var(--color-error);
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact]");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const ok = document.querySelector<HTMLElement>("[data-c-success]");
    const err = document.querySelector<HTMLElement>("[data-c-error]");
    if (ok) ok.hidden = true;
    if (err) err.hidden = true;
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error("fail");
      form.reset();
      if (ok) ok.hidden = false;
    } catch {
      if (err) err.hidden = false;
    }
  });
</script>
