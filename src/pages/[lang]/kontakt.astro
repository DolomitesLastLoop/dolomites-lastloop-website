---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { photo, pos } from "@lib/photos";
import { useTranslations, type Lang } from "@i18n/utils";

export const prerender = false;
const lang = (Astro.params.lang ?? "de") as Lang;
if (!["de", "it", "en"].includes(lang)) return Astro.redirect("/de", 302);
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t("contact.title")}>
  <PageHero
    bg={photo.hero_start}
    position={pos.group}
    eyebrow={t("contact.eyebrow")}
    title={t("contact.title")}
    subtitle={t("contact.subtitle")}
    height="50vh"
  />

  <section class="section">
    <div class="container">
      <div class="cm-grid">
        <form class="card reveal" data-contact novalidate>
          <h2>{t("contact.form.title")}</h2>

          <div class="field">
            <label for="c-name">{t("contact.form.name")}</label>
            <input type="text" id="c-name" name="name" required />
          </div>
          <div class="field">
            <label for="c-email">{t("contact.form.email")}</label>
            <input type="email" id="c-email" name="email" required />
          </div>
          <div class="field">
            <label for="c-message">{t("contact.form.message")}</label>
            <textarea id="c-message" name="message" required></textarea>
          </div>

          <button class="btn btn-primary btn-block btn-arrow" type="submit">
            {t("contact.form.submit")}
          </button>

          <p class="status status-success mt-4" data-c-success hidden>
            {t("contact.form.success")}
          </p>
          <p class="status status-error mt-4" data-c-error hidden>
            {t("contact.form.error")}
          </p>
        </form>

        <aside class="card reveal info-card" data-delay="100">
          <h2>{t("contact.info.title")}</h2>

          <div class="info-row">
            <span class="info-label">{t("contact.email")}</span>
            <a class="info-value" href="mailto:dolomiteslastloop@gmail.com">
              dolomiteslastloop@gmail.com
            </a>
          </div>
          <div class="info-row">
            <span class="info-label">{t("contact.org")}</span>
            <span class="info-value">{t("contact.org.value")}</span>
          </div>
          <div class="info-row">
            <span class="info-label">{t("contact.location")}</span>
            <span class="info-value">{t("contact.location.value")}</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="map-full reveal">
        <iframe
          src="https://www.google.com/maps?q=Seeweg+16,+39034+Toblach+BZ,+Italy&output=embed"
          title={t("contact.location.value")}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .cm-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Both columns are .card with identical padding → identical top offsets.
     Headings inside use the same default margins → tops align as a straight line. */
  .info-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .info-row {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .info-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .info-row:first-of-type {
    padding-top: 0;
  }
  .info-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .info-value {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.5;
  }

  .map-full {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
  }
  .map-full iframe {
    width: 100%;
    height: 350px;
    border: none;
    display: block;
  }

  .status-success {
    color: var(--color-success);
  }
  .status-error {
    color: var(--color-error);
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact]");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const ok = document.querySelector<HTMLElement>("[data-c-success]");
    const err = document.querySelector<HTMLElement>("[data-c-error]");
    if (ok) ok.hidden = true;
    if (err) err.hidden = true;
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error("fail");
      form.reset();
      if (ok) ok.hidden = false;
    } catch {
      if (err) err.hidden = false;
    }
  });
</script>
