---
import BaseLayout from "@layouts/BaseLayout.astro";
import { isAuthenticated, issueSession, verifyPassword } from "@lib/auth";
import { getAdminClient } from "@lib/supabase";

export const prerender = false;

if (isAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin", 302);
}

function clientIp(): string {
  try {
    return Astro.clientAddress;
  } catch {
    return Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() || "unknown";
  }
}

let error: string | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const password = String(form.get("password") || "");
  const ok = verifyPassword(password);

  // Brute-Force-Schutz: 5 Fehlversuche / 15 min → 15 min Lockout pro IP.
  // Die RPC prüft die Sperre VOR der Erfolgs-Verarbeitung — ein korrektes
  // Passwort während einer aktiven Sperre wird ebenfalls abgewiesen.
  const { data: lockedUntil, error: rpcError } = await getAdminClient().rpc(
    "register_login_attempt",
    { p_ip: clientIp(), p_success: ok },
  );

  if (rpcError) {
    // fail-closed: ohne funktionierenden Schutz keine Anmeldung
    // (häufigste Ursache: register_login_attempt aus supabase/schema.sql
    // wurde noch nicht im SQL-Editor ausgeführt)
    console.error("login_attempts RPC fehlgeschlagen:", rpcError.message);
    error = "Anmeldung derzeit nicht möglich. Bitte später erneut versuchen.";
  } else if (lockedUntil) {
    Astro.response.status = 429;
    error = "Zu viele Fehlversuche. Bitte in 15 Minuten erneut versuchen.";
  } else if (ok) {
    issueSession(Astro.cookies);
    return Astro.redirect("/admin", 302);
  } else {
    error = "Falsches Passwort.";
  }
}
---

<BaseLayout lang="de" title="Admin Login" noindex>
  <section class="section">
    <div class="container-narrow login-wrap">
      <div class="card">
        <h1>Admin</h1>
        <p class="text-muted mb-5">Geschützter Bereich. Bitte anmelden.</p>

        {error && <div class="alert alert-error">{error}</div>}

        <form method="POST">
          <div class="field">
            <label for="pw">Passwort</label>
            <input type="password" id="pw" name="password" required autofocus />
          </div>
          <button class="btn btn-primary btn-block" type="submit">Anmelden</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .login-wrap {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .login-wrap .card {
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }
</style>
