---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Zieldatum: 15. Mai 2027, 06:00 Uhr lokale Dolomiten-Zeit (CEST = UTC+2 im Mai).
const TARGET_ISO = "2027-05-15T06:00:00+02:00";

const units = [
  { key: "days", label: t("countdown.days") },
  { key: "hours", label: t("countdown.hours") },
  { key: "minutes", label: t("countdown.minutes") },
  { key: "seconds", label: t("countdown.seconds") },
];
---

<section class="countdown section" aria-labelledby="countdown-title">
  <div class="container-narrow text-center">
    <p class="eyebrow">15.05.2027</p>
    <h2 id="countdown-title">{t("countdown.title")}</h2>

    <div
      class="countdown-grid"
      data-countdown
      data-target={TARGET_ISO}
      role="timer"
      aria-live="off"
    >
      {
        units.map((u) => (
          <div class="cd-unit">
            <span class="cd-num" data-unit={u.key}>--</span>
            <span class="cd-label">{u.label}</span>
          </div>
        ))
      }
    </div>

    <p class="cd-over" data-countdown-over hidden>{t("countdown.over")}</p>
  </div>
</section>

<style>
  .countdown {
    background: var(--color-bg-alt);
  }
  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    max-width: 560px;
    margin: var(--space-6) auto var(--space-5);
  }
  @media (max-width: 480px) {
    .countdown-grid {
      gap: var(--space-3);
    }
  }
  .cd-unit {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }
  .cd-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 8vw, 4.5rem);
    line-height: 1;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .cd-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-dim, var(--color-text));
  }
  .cd-over {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    color: var(--color-accent);
    margin-top: var(--space-4);
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-countdown]");
  if (root) {
    const target = new Date(root.dataset.target || "").getTime();
    const fields: Record<string, HTMLElement | null> = {
      days: root.querySelector('[data-unit="days"]'),
      hours: root.querySelector('[data-unit="hours"]'),
      minutes: root.querySelector('[data-unit="minutes"]'),
      seconds: root.querySelector('[data-unit="seconds"]'),
    };
    const over = document.querySelector<HTMLElement>("[data-countdown-over]");

    const pad = (n: number) => String(n).padStart(2, "0");

    let timer: number | undefined;

    function showEnded() {
      root!.hidden = true;
      if (over) over.hidden = false;
      if (timer) window.clearInterval(timer);
    }

    function tick() {
      const diff = target - Date.now();
      if (!Number.isFinite(target)) {
        if (timer) window.clearInterval(timer);
        return;
      }
      if (diff <= 0) {
        showEnded();
        return;
      }
      const totalSeconds = Math.floor(diff / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      if (fields.days) fields.days.textContent = String(days);
      if (fields.hours) fields.hours.textContent = pad(hours);
      if (fields.minutes) fields.minutes.textContent = pad(minutes);
      if (fields.seconds) fields.seconds.textContent = pad(seconds);
    }

    tick();
    timer = window.setInterval(tick, 1000);
  }
</script>
