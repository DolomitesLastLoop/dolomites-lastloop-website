---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={`mountains ${className}`}
  viewBox="0 0 1440 320"
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <linearGradient id="mountFadeBack" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#1a1a2e" stop-opacity="0.55" />
      <stop offset="100%" stop-color="#0a0a0a" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="mountFadeFront" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#0e0e18" stop-opacity="0.95" />
      <stop offset="100%" stop-color="#0a0a0a" stop-opacity="0.4" />
    </linearGradient>
  </defs>

  <path
    fill="url(#mountFadeBack)"
    d="M0,260 L90,170 L160,210 L240,90 L330,180 L420,120 L520,200 L620,80 L730,180 L820,140 L920,220 L1030,110 L1130,200 L1240,150 L1340,230 L1440,180 L1440,320 L0,320 Z"
  ></path>

  <path
    fill="url(#mountFadeFront)"
    d="M0,300 L80,240 L160,280 L260,200 L360,260 L460,220 L560,290 L660,210 L770,280 L880,230 L990,290 L1100,240 L1210,290 L1320,250 L1440,290 L1440,320 L0,320 Z"
  ></path>
</svg>

<style>
  .mountains {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }
</style>
