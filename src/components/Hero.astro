---
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const slides = [
  { src: "/images/hero-start.jpg", pos: "center center" },
  { src: "/images/day-running-1.jpg", pos: "center 30%" },
  { src: "/images/night-runners.jpg", pos: "center 20%" },
  { src: "/images/emotion-smile.jpg", pos: "center 15%" },
  { src: "/images/night-camp.jpg", pos: "center center" },
];
---

<section class="hero" aria-label={t("hero.title")}>
  <div class="hero-stage" data-parallax aria-hidden="true">
    {
      slides.map((s, i) => (
        <div
          class:list={["slide", { active: i === 0 }]}
          data-slide
          style={`background-image:url(${s.src}); background-position:${s.pos};`}
        />
      ))
    }
    <div class="hero-overlay"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="container hero-inner">
    <p class="hero-eyebrow reveal">2027</p>
    <h1 class="hero-title hero-title-anim" data-hero-title>
      {t("hero.title")}
    </h1>
    <p class="hero-subtitle hero-fade" data-delay="300">{t("hero.subtitle")}</p>
    <p class="hero-teaser hero-fade" data-delay="450">{t("hero.teaser")}</p>

    <div class="hero-cta hero-rise" data-delay="600">
      <a class="btn btn-primary" href={localizePath("/anmeldung", lang)}>
        {t("hero.cta_signup")}
      </a>
      <a class="btn btn-on-dark" href={localizePath("/race-info", lang)}>
        {t("hero.cta_more")}
      </a>
    </div>
  </div>

  <div class="hero-dots" role="tablist" aria-label="Slide navigation">
    {
      slides.map((_, i) => (
        <button
          type="button"
          class:list={["dot", { active: i === 0 }]}
          data-dot={i}
          role="tab"
          aria-label={`Slide ${i + 1}`}
        />
      ))
    }
  </div>

  <a class="hero-scroll-cue" href="#after-hero" aria-label="Scroll">
    <span class="cue-line"></span>
    <span class="cue-arrow">↓</span>
  </a>

  <span class="hero-credit">© Harald Wisthaler</span>
  <span id="after-hero" aria-hidden="true"></span>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
    color: #ffffff;
  }

  .hero-stage {
    position: absolute;
    inset: 0;
    z-index: -2;
    will-change: transform;
  }

  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 1500ms var(--ease-emphasis),
      transform 9000ms linear;
  }
  .slide.active {
    opacity: 1;
    transform: scale(1.12);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.3) 30%,
      rgba(0, 0, 0, 0.42) 70%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 35%,
      rgba(0, 0, 0, 0.5) 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--space-9) var(--space-5);
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #ffffff;
    padding: 0.45rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 4px;
    margin-bottom: var(--space-6);
    font-weight: 500;
    background: rgba(45, 74, 107, 0.18);
    backdrop-filter: blur(6px);
  }

  /* Letter-spacing reveal for hero title */
  .hero-title {
    font-size: clamp(3.5rem, 9vw, 8.5rem);
    margin-bottom: var(--space-4);
    color: #ffffff;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.55);
    line-height: 0.95;
  }
  .hero-title-anim {
    opacity: 0;
    letter-spacing: -0.5em;
    transform: translateY(8px);
    transition:
      opacity 1000ms var(--ease-emphasis),
      letter-spacing 1000ms var(--ease-emphasis),
      transform 1000ms var(--ease-emphasis);
  }
  .hero-title-anim.is-on {
    opacity: 1;
    letter-spacing: 0.06em;
    transform: none;
  }

  /* Sequential fades */
  .hero-fade,
  .hero-rise {
    opacity: 0;
    transition:
      opacity 800ms var(--ease-emphasis),
      transform 800ms var(--ease-emphasis);
  }
  .hero-fade {
    transform: translateY(8px);
  }
  .hero-rise {
    transform: translateY(20px);
  }
  .hero-fade.is-on,
  .hero-rise.is-on {
    opacity: 1;
    transform: none;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: 0.42em;
    color: rgba(255, 255, 255, 0.92);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    font-weight: 400;
  }

  .hero-teaser {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(255, 255, 255, 0.88);
    max-width: 55ch;
    margin: 0 auto var(--space-7);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    pointer-events: none;
    z-index: 2;
  }

  .hero-dots {
    position: absolute;
    bottom: calc(var(--space-7) + var(--space-3));
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: var(--space-3);
    z-index: 2;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), transform var(--transition),
      box-shadow var(--transition);
  }
  .dot:hover {
    background: rgba(255, 255, 255, 0.7);
  }
  .dot.active {
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.18);
    transform: scale(1.1);
  }

  .hero-scroll-cue {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.4rem;
    text-decoration: none;
  }
  .cue-line {
    width: 1px;
    height: 44px;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(255, 255, 255, 0.7),
      transparent
    );
    animation: cueLine 2.4s var(--ease) infinite;
  }
  .cue-arrow {
    line-height: 1;
    animation: cueArrow 2.4s var(--ease) infinite;
  }
  @keyframes cueLine {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 1; }
  }
  @keyframes cueArrow {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(4px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cue-line,
    .cue-arrow,
    .slide {
      animation: none;
      transition: opacity 200ms linear;
      transform: none !important;
    }
    .hero-title-anim,
    .hero-fade,
    .hero-rise {
      opacity: 1;
      letter-spacing: normal;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // ─────────────────────── Slideshow ───────────────────────
  const slides = Array.from(document.querySelectorAll<HTMLElement>("[data-slide]"));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-dot]"));
  let active = 0;
  let timer: number | undefined;

  function show(i: number) {
    slides[active]?.classList.remove("active");
    dots[active]?.classList.remove("active");
    active = (i + slides.length) % slides.length;
    slides[active]?.classList.add("active");
    dots[active]?.classList.add("active");
  }

  function startAuto() {
    if (slides.length < 2) return;
    timer = window.setInterval(() => show(active + 1), 6000);
  }

  function pauseAuto() {
    if (timer) {
      clearInterval(timer);
      timer = undefined;
    }
  }

  dots.forEach((d, i) =>
    d.addEventListener("click", () => {
      pauseAuto();
      show(i);
      startAuto();
    }),
  );

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    startAuto();
  }

  // ─────────────────────── Parallax 0.5x ───────────────────
  const stage = document.querySelector<HTMLElement>(".hero-stage");
  let raf = 0;
  function applyParallax() {
    if (!stage) return;
    const y = window.scrollY;
    stage.style.transform = `translate3d(0, ${y * 0.5}px, 0)`;
    raf = 0;
  }
  if (stage && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    window.addEventListener(
      "scroll",
      () => {
        if (!raf) raf = requestAnimationFrame(applyParallax);
      },
      { passive: true },
    );
  }

  // ─────────────────────── Title letter-spacing reveal ───────
  // Run on next frame so the initial state paints first.
  requestAnimationFrame(() => {
    document
      .querySelectorAll<HTMLElement>(
        ".hero-title-anim, .hero-fade, .hero-rise",
      )
      .forEach((el) => {
        const delay = Number(el.dataset.delay || "0");
        setTimeout(() => el.classList.add("is-on"), delay);
      });
  });
</script>
