---
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" aria-label={t("hero.title")}>
  <div class="hero-bg" aria-hidden="true">
    <img
      src="/images/hero-start.jpg"
      alt=""
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-inner">
    <p class="hero-eyebrow reveal">15. Mai 2027 · Première</p>
    <h1 class="hero-title reveal">{t("hero.title")}</h1>
    <p class="hero-subtitle reveal">{t("hero.subtitle")}</p>
    <p class="hero-teaser reveal">{t("hero.teaser")}</p>

    <div class="hero-cta reveal">
      <a class="btn btn-primary" href={localizePath("/anmeldung", lang)}>
        {t("hero.cta_signup")}
      </a>
      <a class="btn btn-on-dark" href={localizePath("/race-info", lang)}>
        {t("hero.cta_more")}
      </a>
    </div>
  </div>

  <a class="hero-credit" href="#" aria-label="Photo credit">
    © Wisthaler Photography
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
    color: #ffffff;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.35) 0%,
        rgba(0, 0, 0, 0.4) 60%,
        rgba(0, 0, 0, 0.55) 100%
      );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--space-9) var(--space-5);
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--color-accent);
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    margin-bottom: var(--space-5);
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(3rem, 9vw, 7.5rem);
    margin-bottom: var(--space-3);
    letter-spacing: 0.03em;
    color: #ffffff;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.85rem);
    letter-spacing: 0.18em;
    color: #ffd9b8;
    text-transform: uppercase;
    margin-bottom: var(--space-5);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }

  .hero-teaser {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    color: rgba(255, 255, 255, 0.92);
    max-width: 52ch;
    margin: 0 auto var(--space-7);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    pointer-events: none;
    z-index: 2;
  }
</style>
