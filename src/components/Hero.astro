---
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const slides = [
  { src: "/images/hero-start.jpg", pos: "center center" },
  { src: "/images/day-running-1.jpg", pos: "center 30%" },
  { src: "/images/night-runners.jpg", pos: "center 20%" },
  { src: "/images/emotion-smile.jpg", pos: "center 15%" },
  { src: "/images/night-camp.jpg", pos: "center center" },
];
const SLIDE_DURATION_MS = 6000;
---

<section class="hero" aria-label={t("hero.title")}>
  <div class="hero-stage" data-parallax aria-hidden="true">
    {
      slides.map((s, i) => (
        <div
          class:list={["slide", { active: i === 0 }]}
          data-slide
          style={`background-image:url(${s.src}); background-position:${s.pos};`}
        />
      ))
    }
    <div class="hero-overlay"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="container hero-inner">
    <p class="hero-eyebrow reveal">2027</p>

    <h1 class="hero-title hero-title-anim" data-hero-title>
      {t("hero.title")}
    </h1>

    <div class="hero-rule" aria-hidden="true">
      <span></span>
    </div>

    <p class="hero-subtitle hero-fade" data-delay="350">{t("hero.subtitle")}</p>
    <p class="hero-teaser hero-fade" data-delay="500">{t("hero.teaser")}</p>

    <div class="hero-cta hero-rise" data-delay="650">
      <a class="btn btn-primary btn-arrow" href={localizePath("/anmeldung", lang)}>
        {t("hero.cta_signup")}
      </a>
      <a class="btn btn-on-dark btn-arrow" href={localizePath("/race-info", lang)}>
        {t("hero.cta_more")}
      </a>
    </div>

    <p class="hero-subtext hero-fade" data-delay="900">{t("hero.subtext")}</p>
  </div>

  <div class="hero-dots" role="tablist" aria-label="Slide navigation">
    {
      slides.map((_, i) => (
        <button
          type="button"
          class:list={["bar", { active: i === 0 }]}
          data-dot={i}
          role="tab"
          aria-label={`Slide ${i + 1}`}
        >
          <span class="bar-fill" />
        </button>
      ))
    }
  </div>

  <span class="hero-credit">© Harald Wisthaler</span>
  <span id="after-hero" aria-hidden="true"></span>
</section>

<style define:vars={{ slideMs: SLIDE_DURATION_MS + "ms" }}>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
    color: #ffffff;
  }

  .hero-stage {
    position: absolute;
    inset: 0;
    z-index: -2;
    will-change: transform;
  }

  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 1500ms var(--ease-emphasis),
      transform 9000ms linear;
  }
  .slide.active {
    opacity: 1;
    transform: scale(1.12);
  }

  /* Dramatic gradient from top to bottom */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(20, 35, 55, 0.3) 0%,
      rgba(20, 35, 55, 0.45) 40%,
      rgba(20, 35, 55, 0.7) 80%,
      rgba(20, 35, 55, 0.85) 100%
    );
  }
  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 30%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--space-9) var(--space-5);
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #ffffff;
    padding: 0.45rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 4px;
    margin-bottom: var(--space-6);
    font-weight: 500;
    background: rgba(45, 74, 107, 0.18);
    backdrop-filter: blur(6px);
  }

  .hero-title {
    font-size: clamp(3.5rem, 10vw, 9.5rem);
    margin-bottom: var(--space-4);
    color: #ffffff;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.55);
    line-height: 0.95;
  }
  @media (max-width: 600px) {
    .hero-title {
      font-size: clamp(3rem, 18vw, 6rem);
    }
  }

  .hero-title-anim {
    opacity: 0;
    letter-spacing: -0.5em;
    transform: translateY(8px);
    transition:
      opacity 1000ms var(--ease-emphasis),
      letter-spacing 1000ms var(--ease-emphasis),
      transform 1000ms var(--ease-emphasis);
  }
  .hero-title-anim.is-on {
    opacity: 1;
    letter-spacing: 0.05em;
    transform: none;
  }

  /* Thin line under title that draws in */
  .hero-rule {
    height: 1px;
    width: min(280px, 60vw);
    margin: 0 auto var(--space-6);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.18);
  }
  .hero-rule span {
    display: block;
    height: 100%;
    background: #ffffff;
    transform: scaleX(0);
    transform-origin: left center;
    animation: heroRule 2s 700ms var(--ease-emphasis) forwards;
  }
  @keyframes heroRule {
    to {
      transform: scaleX(1);
    }
  }

  .hero-fade,
  .hero-rise {
    opacity: 0;
    transition:
      opacity 800ms var(--ease-emphasis),
      transform 800ms var(--ease-emphasis);
  }
  .hero-fade {
    transform: translateY(8px);
  }
  .hero-rise {
    transform: translateY(20px);
  }
  .hero-fade.is-on,
  .hero-rise.is-on {
    opacity: 1;
    transform: none;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 2vw, 1.45rem);
    letter-spacing: 0.5em;
    color: rgba(255, 255, 255, 0.92);
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    font-weight: 400;
  }

  .hero-teaser {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(255, 255, 255, 0.88);
    max-width: 55ch;
    margin: 0 auto var(--space-7);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-7);
  }

  .hero-subtext {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 400;
    margin: 0 auto;
    max-width: 50ch;
  }

  .hero-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    pointer-events: none;
    z-index: 2;
  }

  /* Slide-progress bar dots */
  .hero-dots {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: var(--space-3);
    z-index: 2;
  }
  .bar {
    position: relative;
    width: 44px;
    height: 2px;
    border: none;
    padding: var(--space-2) 0;
    background: transparent;
    cursor: pointer;
    overflow: visible;
  }
  .bar::before {
    content: "";
    position: absolute;
    inset: 50% 0 auto 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.35);
    transition: background var(--transition);
  }
  .bar:hover::before {
    background: rgba(255, 255, 255, 0.7);
  }
  .bar-fill {
    position: absolute;
    inset: 50% 0 auto 0;
    height: 2px;
    background: #ffffff;
    transform-origin: left center;
    transform: scaleX(0);
  }
  .bar.active .bar-fill {
    animation: barFill var(--slideMs) linear forwards;
  }
  @keyframes barFill {
    to {
      transform: scaleX(1);
    }
  }
  .bar.active::before {
    background: rgba(255, 255, 255, 0.85);
  }

  @media (prefers-reduced-motion: reduce) {
    .slide,
    .hero-title-anim,
    .hero-fade,
    .hero-rise,
    .hero-rule span,
    .bar-fill {
      animation: none !important;
      transition: opacity 200ms linear;
      opacity: 1 !important;
      letter-spacing: normal !important;
      transform: none !important;
    }
  }
</style>

<script define:vars={{ duration: SLIDE_DURATION_MS }}>
  // Slideshow with line-fill animation reset
  const slides = Array.from(document.querySelectorAll(".slide"));
  const bars = Array.from(document.querySelectorAll(".bar"));
  let active = 0;
  let timer;

  function show(i) {
    slides[active]?.classList.remove("active");
    bars[active]?.classList.remove("active");
    active = (i + slides.length) % slides.length;
    slides[active]?.classList.add("active");
    bars[active]?.classList.add("active");
    // force reflow so the fill animation restarts
    const fill = bars[active]?.querySelector(".bar-fill");
    if (fill) {
      fill.style.animation = "none";
      void fill.offsetWidth;
      fill.style.animation = "";
    }
  }

  function startAuto() {
    if (slides.length < 2) return;
    timer = setInterval(() => show(active + 1), duration);
  }
  function pauseAuto() {
    if (timer) {
      clearInterval(timer);
      timer = undefined;
    }
  }
  bars.forEach((b, i) =>
    b.addEventListener("click", () => {
      pauseAuto();
      show(i);
      startAuto();
    }),
  );
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    startAuto();
  }

  // Parallax 0.5x
  const stage = document.querySelector(".hero-stage");
  let raf = 0;
  function applyParallax() {
    if (!stage) return;
    const y = window.scrollY;
    stage.style.transform = `translate3d(0, ${y * 0.5}px, 0)`;
    raf = 0;
  }
  if (stage && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    window.addEventListener(
      "scroll",
      () => {
        if (!raf) raf = requestAnimationFrame(applyParallax);
      },
      { passive: true },
    );
  }

  // Sequential reveals
  requestAnimationFrame(() => {
    document
      .querySelectorAll(".hero-title-anim, .hero-fade, .hero-rise")
      .forEach((el) => {
        const delay = Number(el.dataset.delay || "0");
        setTimeout(() => el.classList.add("is-on"), delay);
      });
  });
</script>
