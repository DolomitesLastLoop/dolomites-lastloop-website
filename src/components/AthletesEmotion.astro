---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const cols = [
  { src: "/images/night-runners.jpg", overlay: t("athletes.col1.overlay") },
  { src: "/images/hero-start.jpg", overlay: t("athletes.col2.overlay"), wide: true },
  { src: "/images/emotion-smile.jpg", overlay: t("athletes.col3.overlay") },
];
---

<section class="athletes section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t("athletes.eyebrow")}</span>
    </div>

    <div class="cols">
      {
        cols.map((c, idx) => (
          <figure
            class:list={["col reveal reveal-scale", { wide: c.wide }]}
            data-delay={String(idx * 120)}
          >
            <img src={c.src} alt="" loading="lazy" />
            <figcaption>
              <span class="overlay-text">{c.overlay}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="tagline reveal mt-7">{t("athletes.tagline")}</p>
  </div>
</section>

<style>
  .cols {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1fr;
    gap: var(--space-4);
  }
  @media (max-width: 900px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }

  .col {
    position: relative;
    margin: 0;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    cursor: pointer;
  }
  .col.wide {
    aspect-ratio: 4 / 5;
  }
  @media (max-width: 900px) {
    .col,
    .col.wide {
      aspect-ratio: 4 / 3;
    }
  }

  .col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 700ms var(--ease-emphasis),
      filter 500ms var(--ease);
    filter: brightness(0.78);
  }
  .col:hover img,
  .col:focus-within img {
    transform: scale(1.05);
    filter: brightness(1);
  }

  .col figcaption {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--space-6);
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(20, 35, 55, 0) 30%,
      rgba(20, 35, 55, 0.85) 100%
    );
  }
  .overlay-text {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.6);
    transition: opacity 400ms var(--ease);
  }
  .col:hover .overlay-text,
  .col:focus-within .overlay-text {
    opacity: 0;
  }

  .tagline {
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
</style>
