---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="emotion" aria-label={t("emotion.quote")}>
  <aside class="strip strip-left" aria-hidden="true">
    <img src="/images/emotion-smile.jpg" alt="" loading="lazy" />
  </aside>

  <aside class="strip strip-right" aria-hidden="true">
    <img src="/images/night-runners.jpg" alt="" loading="lazy" />
  </aside>

  <svg
    class="mountain-bg"
    viewBox="0 0 1440 360"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M0,260 L150,180 L260,220 L380,90 L500,180 L640,120 L780,200 L900,80 L1040,180 L1180,140 L1320,220 L1440,160 L1440,360 L0,360 Z"
      fill="rgba(255,255,255,0.04)"
    />
    <path
      d="M0,310 L120,240 L240,280 L380,200 L500,260 L640,220 L780,290 L900,200 L1020,280 L1140,230 L1280,290 L1440,250 L1440,360 L0,360 Z"
      fill="rgba(255,255,255,0.02)"
    />
  </svg>

  <div class="emotion-inner">
    <blockquote class="quote reveal" data-delay="100">
      <p>{t("emotion.quote")}</p>
      <cite>{t("emotion.attribution")}</cite>
    </blockquote>
  </div>
</section>

<style>
  .emotion {
    position: relative;
    background: #1a2a3a;
    color: #ffffff;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .strip {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 16vw;
    overflow: hidden;
    opacity: 0.75;
  }
  .strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) saturate(0.9);
  }
  .strip::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 42, 58, 0) 0%,
      rgba(26, 42, 58, 0.9) 90%,
      rgba(26, 42, 58, 1) 100%
    );
  }
  .strip-left {
    left: 0;
  }
  .strip-right {
    right: 0;
  }
  .strip-right::after {
    background: linear-gradient(
      to left,
      rgba(26, 42, 58, 0) 0%,
      rgba(26, 42, 58, 0.9) 90%,
      rgba(26, 42, 58, 1) 100%
    );
  }
  @media (max-width: 800px) {
    .strip {
      width: 0;
      display: none;
    }
  }

  .mountain-bg {
    position: absolute;
    inset: auto 0 0 0;
    width: 100%;
    height: auto;
    z-index: 0;
    pointer-events: none;
  }

  .emotion-inner {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--space-9) var(--space-6);
    text-align: center;
  }

  .quote p {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    letter-spacing: 0.04em;
    line-height: 1.05;
    color: #ffffff;
    margin: 0 0 var(--space-5);
    text-transform: uppercase;
  }
  .quote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.8rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
