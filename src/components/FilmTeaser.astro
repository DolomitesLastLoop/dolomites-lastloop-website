---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="film" aria-label={t("film.tagline")}>
  <div class="film-bg" aria-hidden="true">
    <img src="/images/night-camp.jpg" alt="" loading="lazy" />
    <div class="film-overlay"></div>
  </div>

  <div class="container film-inner">
    <span class="eyebrow on-dark reveal">{t("film.eyebrow")}</span>

    <button class="play" type="button" aria-label={t("film.play")} disabled>
      <span class="play-icon" aria-hidden="true">▶</span>
      <span class="play-pulse" aria-hidden="true"></span>
      <span class="play-pulse delayed" aria-hidden="true"></span>
    </button>

    <p class="film-text reveal" data-delay="200">{t("film.tagline")}</p>
  </div>

  <span class="film-credit">© Harald Wisthaler</span>
</section>

<style>
  .film {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    color: #ffffff;
    overflow: hidden;
    isolation: isolate;
  }
  .film-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .film-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .film-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(20, 35, 55, 0.55) 0%,
      rgba(20, 35, 55, 0.78) 100%
    );
  }

  .film-inner {
    position: relative;
    text-align: center;
    padding: var(--space-9) var(--space-6);
  }

  .eyebrow.on-dark {
    color: rgba(255, 255, 255, 0.85);
  }
  .eyebrow.on-dark::before {
    background: rgba(255, 255, 255, 0.6);
  }

  .play {
    position: relative;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    cursor: not-allowed;
    margin: var(--space-6) auto var(--space-6);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition:
      background var(--transition),
      transform var(--transition),
      border-color var(--transition);
  }
  .play:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #ffffff;
    transform: scale(1.04);
  }
  .play-icon {
    font-size: 2rem;
    margin-left: 6px; /* optical centring of the ▶ glyph */
    line-height: 1;
  }
  .play-pulse {
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.45);
    animation: filmPulse 2.4s var(--ease) infinite;
  }
  .play-pulse.delayed {
    animation-delay: 1.2s;
  }
  @keyframes filmPulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .play-pulse {
      animation: none;
      opacity: 0;
    }
  }

  .film-text {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 auto;
    max-width: 32ch;
  }

  .film-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    pointer-events: none;
  }
</style>
