---
import { useTranslations, localizePath, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = 2027;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="col col-brand">
      <a class="footer-brand" href={localizePath("/", lang)}>
        <img
          src="/images/Logo.jpeg"
          alt=""
          width="44"
          height="44"
          class="footer-logo"
          loading="lazy"
          decoding="async"
        />
        <span>Dolomites Last Loop</span>
      </a>
      <p class="text-dim">{t("site.tagline")}</p>
      <p class="text-dim">{t("footer.org")}</p>
    </div>

    <div class="col">
      <h4>Info</h4>
      <ul>
        <li><a href={localizePath("/race-info", lang)}>{t("nav.race_info")}</a></li>
        <li><a href={localizePath("/galerie", lang)}>{t("nav.gallery")}</a></li>
        <li><a href={localizePath("/faq", lang)}>{t("nav.faq")}</a></li>
        <li><a href={localizePath("/ergebnisse", lang)}>{t("nav.results")}</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Legal</h4>
      <ul>
        <li><a href={localizePath("/datenschutz", lang)}>{t("footer.privacy")}</a></li>
        <li><a href={localizePath("/agb", lang)}>{t("footer.terms")}</a></li>
        <li><a href={localizePath("/barrierefreiheit", lang)}>{t("footer.accessibility")}</a></li>
        <li><a href={localizePath("/rueckerstattung", lang)}>{t("footer.refund")}</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Social</h4>
      <ul class="social">
        <li>
          <a href="https://instagram.com/dolomiteslastloop" rel="noopener" target="_blank" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            Instagram
          </a>
        </li>
        <li>
          <a href="https://facebook.com/dolomiteslastloop" rel="noopener" target="_blank" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            Facebook
          </a>
        </li>
        <li>
          <a href="mailto:dolomiteslastloop@gmail.com">
            dolomiteslastloop@gmail.com
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="text-dim">{t("footer.copyright", { year })}</p>
    <p class="text-dim">Sport OK Toblach</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-9);
    padding: var(--space-8) 0 var(--space-5);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--space-6);
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }
  .footer-brand:hover {
    color: var(--color-primary);
  }
  .footer-logo {
    width: 44px;
    height: 44px;
    object-fit: cover;
    border-radius: 6px;
    background: #ffffff;
  }

  .col h4 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .col a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .col a:hover {
    color: var(--color-accent);
  }

  .social a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-bottom {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  @media (max-width: 800px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
