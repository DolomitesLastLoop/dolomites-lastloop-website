---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// These quotes stay in the runner's original language on purpose.
const items = [
  {
    quote:
      "Die Challenge an sich, dass ihr das überhaupt organisiert habt, top. Und der Speaker Günther cooler Typ. Eigentlich war es eine lange \"Reise\" bei der man neue Bekanntschaften gemacht hat und mit Gleichgesinnten einen Austausch hatte.",
    name: "Marc",
    loops: 24,
    year: 2026,
  },
  {
    // anonym eingewilligt – KEIN Name
    quote:
      "Die Atmosphäre im Camp, die Small Talks mit verschiedenen Runnern in jedem Loop, die gesamte Stimmung war super.",
    name: "Teilnehmer",
    loops: 16,
    year: 2026,
  },
  {
    // anonym eingewilligt – KEIN Name
    quote:
      "Der gesamte Tag war unvergesslich – das Team war permanent freundlich und zuvorkommend. Die Organisation der Veranstaltung war TOP.",
    name: "Teilnehmerin",
    loops: 11,
    year: 2026,
  },
  {
    // anonym eingewilligt – KEIN Name (zweite Antwort derselben Person, bewusst separate Karte)
    quote:
      "Am liebsten würde ich den gesamten Tag nochmals erleben - DANKE für die Planung und perfekte Durchführung vom Backyard Ultra! Ich freue mich schon auf 2027! :)",
    name: "Teilnehmerin",
    loops: 11,
    year: 2026,
  },
];
---

<section class="testimonials section">
  <div class="container">
    <div class="section-head reveal text-center">
      <span class="eyebrow">{t("testimonials.eyebrow")}</span>
      <h2 class="reveal-left">{t("testimonials.title")}</h2>
    </div>

    <div class="grid grid-3 mt-7">
      {
        items.map((it, idx) => (
          <article class="t-card reveal" data-delay={String(idx * 120)}>
            <span class="t-mark" aria-hidden="true">“</span>
            <blockquote>
              <p>{it.quote}</p>
              <footer>
                <span class="t-name">{it.name}</span>
                <span class="t-meta">
                  {it.loops} Loops · {it.year}
                </span>
              </footer>
            </blockquote>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .t-card {
    position: relative;
    padding: var(--space-7) var(--space-6) var(--space-6);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      border-color var(--transition);
  }
  .t-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-primary-light);
  }

  .t-mark {
    position: absolute;
    top: -8px;
    left: var(--space-5);
    font-family: var(--font-display);
    font-size: 6rem;
    line-height: 0.7;
    color: var(--color-primary);
    opacity: 0.16;
    user-select: none;
    pointer-events: none;
  }

  .t-card blockquote {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .t-card blockquote p {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--color-text);
  }
  .t-card footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .t-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .t-meta {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
</style>
