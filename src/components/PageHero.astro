---
interface Props {
  bg: string;
  position?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  height?: string;
}
const {
  bg,
  position = "center center",
  eyebrow,
  title,
  subtitle,
  align = "center",
  height = "56vh",
} = Astro.props;
---

<section
  class:list={["page-hero", `align-${align}`]}
  style={`--ph-height:${height}`}
>
  <div class="ph-bg" aria-hidden="true">
    <img
      src={bg}
      alt=""
      loading="eager"
      fetchpriority="high"
      style={`object-position:${position}`}
    />
    <div class="ph-overlay"></div>
  </div>

  <div class="container ph-inner">
    {eyebrow && <span class="eyebrow on-dark reveal">{eyebrow}</span>}
    <h1 class="ph-title reveal" data-delay="100">{title}</h1>
    {subtitle && <p class="ph-subtitle reveal" data-delay="200">{subtitle}</p>}
  </div>

  <span class="ph-credit">© Harald Wisthaler</span>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: var(--ph-height, 56vh);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
    color: #ffffff;
  }
  .ph-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .ph-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ph-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(20, 35, 55, 0.35) 0%,
      rgba(20, 35, 55, 0.55) 50%,
      rgba(20, 35, 55, 0.8) 100%
    );
  }

  .ph-inner {
    position: relative;
    padding: var(--space-8) var(--space-5) var(--space-8);
  }
  .align-center .ph-inner {
    text-align: center;
    margin: 0 auto;
  }
  .align-left .ph-inner {
    text-align: left;
  }

  .eyebrow.on-dark {
    color: rgba(255, 255, 255, 0.95);
  }
  .eyebrow.on-dark::before {
    background: rgba(255, 255, 255, 0.7);
  }

  .ph-title {
    font-size: clamp(3rem, 10vw, 8rem);
    letter-spacing: 0.05em;
    line-height: 0.95;
    margin: var(--space-3) 0 var(--space-4);
    color: #ffffff;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.55);
  }
  .ph-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.6vw, 1.4rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }

  .ph-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    pointer-events: none;
  }
</style>
