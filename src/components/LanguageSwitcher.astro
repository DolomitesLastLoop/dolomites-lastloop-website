---
import { alternateLanguages, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const options = alternateLanguages(lang, Astro.url.pathname);
---

<div class="lang" role="group" aria-label="Language switcher">
  {
    options.map((opt, idx) => (
      <>
        {idx > 0 && <span class="sep" aria-hidden="true">|</span>}
        <a
          href={opt.href}
          class:list={["lang-link", { active: opt.current }]}
          hreflang={opt.lang}
          aria-current={opt.current ? "page" : undefined}
        >
          {opt.lang.toUpperCase()}
        </a>
      </>
    ))
  }
</div>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .lang-link {
    color: var(--color-text-dim);
    padding: 0.25rem 0.4rem;
    transition: color var(--transition);
  }
  .lang-link.active,
  .lang-link:hover {
    color: var(--color-accent);
  }
  .sep {
    color: var(--color-border-strong);
  }
</style>
