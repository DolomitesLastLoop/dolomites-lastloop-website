---
/**
 * Goldene Scroll-Progress-Linie am rechten Rand. Baut sich beim Scrollen
 * auf (scaleY via GSAP, cinematic.ts). Nur Desktop; ohne JS / bei
 * reduced-motion bleibt sie unsichtbar (rein dekorativ).
 */
---

<div class="scroll-progress" data-scroll-progress aria-hidden="true">
  <span data-scroll-progress-bar></span>
</div>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    right: 0;
    width: 3px;
    height: 100vh;
    z-index: 90;
    pointer-events: none;
    background: rgba(201, 168, 76, 0.14);
    opacity: 0;
    transition: opacity 600ms var(--ease-emphasis);
  }
  .scroll-progress.is-active {
    opacity: 1;
  }
  .scroll-progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #e8d9a0 0%, var(--color-gold) 100%);
    box-shadow: 0 0 10px rgba(201, 168, 76, 0.5);
    transform: scaleY(0);
    transform-origin: top center;
  }
  @media (max-width: 899px) {
    .scroll-progress {
      display: none;
    }
  }
</style>
