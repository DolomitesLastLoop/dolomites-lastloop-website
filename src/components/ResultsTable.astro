---
import { useTranslations, type Lang } from "@i18n/utils";
import data from "@/data/results-2026.json";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

type Row = {
  bib: number;
  name: string;
  gender: "M" | "W";
  loops: number;
  distanceKm: number;
  status: string;
  label?: string;
};

// Stable sort by loops (desc) — the official Backyard classification.
const rows = [...(data.results as Row[])].sort((a, b) => b.loops - a.loops);
const total = rows.length;

// Competition ranking: ties share a place (1, 1, 3, …).
const place = (r: Row) => rows.filter((x) => x.loops > r.loops).length + 1;

// Gold / silver / bronze for the three best loop counts (ties included).
const tiers = [...new Set(rows.map((r) => r.loops))].sort((a, b) => b - a);
const medal = (r: Row) => {
  const i = tiers.indexOf(r.loops);
  return i === 0 ? "gold" : i === 1 ? "silver" : i === 2 ? "bronze" : "";
};

const locale = lang === "en" ? "en-GB" : lang === "it" ? "it-IT" : "de-DE";
const fmtKm = new Intl.NumberFormat(locale, {
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});

const labelText = (label: string) =>
  label === "1st Woman"
    ? t("results2026.label.first_woman")
    : t("results2026.label.first_man");
---

<article class="rt" data-results-table>
  <header class="rt-head reveal">
    <div class="rt-head-text">
      <h2 class="rt-title">{t("results.year.2026")}</h2>
      <p class="rt-note">{t("results2026.note")}</p>
    </div>
    <div class="rt-head-stat" aria-hidden="true">
      <span class="rt-head-num">{tiers[0]}</span>
      <span class="rt-head-lbl">{t("results.col.loops")}</span>
    </div>
  </header>

  <div class="rt-toolbar reveal" data-delay="100">
    <label class="rt-search">
      <span class="sr-only">{t("results2026.search.label")}</span>
      <svg
        class="rt-search-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.8-3.8"></path>
      </svg>
      <input
        type="search"
        data-rt-search
        placeholder={t("results2026.search.placeholder")}
        autocomplete="off"
      />
    </label>

    <div
      class="rt-chips"
      role="group"
      aria-label={t("results2026.filter.label")}
    >
      <button type="button" class="rt-chip is-active" data-rt-filter="all">
        {t("results2026.filter.all")}
      </button>
      <button type="button" class="rt-chip" data-rt-filter="M">
        {t("results2026.filter.m")}
      </button>
      <button type="button" class="rt-chip" data-rt-filter="W">
        {t("results2026.filter.w")}
      </button>
    </div>

    <p class="rt-count" aria-live="polite">
      <span class="rt-count-num" data-rt-count>{total}</span>
      <span class="rt-count-rest">/ {total}</span>
    </p>
  </div>

  <div class="rt-table-wrap">
    <table class="rt-table">
      <thead>
        <tr>
          <th class="num">{t("results.col.place")}</th>
          <th class="num">{t("results2026.col.bib")}</th>
          <th>{t("results.col.name")}</th>
          <th>{t("results2026.col.cat")}</th>
          <th class="num">{t("results.col.loops")}</th>
          <th class="num">{t("results2026.col.km")}</th>
          <th>{t("results2026.col.status")}</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((r, i) => (
            <tr
              class={medal(r) ? `is-${medal(r)}` : undefined}
              data-name={r.name}
              data-gender={r.gender}
              style={i < 10 ? `--d:${100 + i * 80}ms` : undefined}
            >
              <td class="num place">
                {medal(r) ? <span class="rt-medal" aria-hidden="true" /> : null}
                {place(r)}
              </td>
              <td class="num dim">{r.bib}</td>
              <td class="name">
                {r.name}
                {r.label ? (
                  <span class="rt-badge">{labelText(r.label)}</span>
                ) : null}
              </td>
              <td class="dim">{r.gender}</td>
              <td class="num loops">{r.loops}</td>
              <td class="num dim">{fmtKm.format(r.distanceKm)}</td>
              <td>
                <span class="rt-status">{r.status.toUpperCase()}</span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class="rt-empty" data-rt-empty hidden>{t("results2026.empty")}</p>
</article>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-results-table]")
    .forEach((root) => {
      const input = root.querySelector<HTMLInputElement>("[data-rt-search]");
      const chips = root.querySelectorAll<HTMLButtonElement>("[data-rt-filter]");
      const rows = root.querySelectorAll<HTMLTableRowElement>("tbody tr");
      const countEl = root.querySelector<HTMLElement>("[data-rt-count]");
      const emptyEl = root.querySelector<HTMLElement>("[data-rt-empty]");
      if (!input || !countEl || !emptyEl) return;

      let gender = "all";
      const norm = (s: string) =>
        s
          .toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "");

      const apply = () => {
        const q = norm(input.value.trim());
        let shown = 0;
        rows.forEach((tr) => {
          const okGender = gender === "all" || tr.dataset.gender === gender;
          const okQuery = !q || norm(tr.dataset.name ?? "").includes(q);
          const visible = okGender && okQuery;
          tr.hidden = !visible;
          if (visible) shown++;
        });
        countEl.textContent = String(shown);
        emptyEl.hidden = shown !== 0;
      };

      input.addEventListener("input", apply);
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          gender = chip.dataset.rtFilter ?? "all";
          chips.forEach((c) => c.classList.toggle("is-active", c === chip));
          apply();
        });
      });
    });
</script>

<style>
  .rt {
    background: linear-gradient(165deg, #233a52 0%, #1a2a3a 55%, #16222f 100%);
    border: 1px solid rgba(201, 168, 76, 0.22);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-deep);
    overflow: hidden;
  }

  /* ---- Head ---- */
  .rt-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-7) var(--space-7) var(--space-5);
  }
  .rt-title {
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3.4vw, 2.8rem);
    letter-spacing: 0.06em;
    color: #faf6f0;
  }
  .rt-note {
    margin: 0;
    max-width: 56ch;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(250, 246, 240, 0.62);
  }
  .rt-head-stat {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-6);
    border: 1px solid rgba(201, 168, 76, 0.35);
    border-radius: var(--radius);
    background: rgba(201, 168, 76, 0.07);
  }
  .rt-head-num {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 3.6rem);
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--color-gold);
  }
  .rt-head-lbl {
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(250, 246, 240, 0.55);
  }

  /* ---- Toolbar ---- */
  .rt-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    padding: 0 var(--space-7) var(--space-5);
  }
  .rt-search {
    position: relative;
    flex: 1 1 240px;
    max-width: 380px;
    display: block;
  }
  .rt-search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: rgba(250, 246, 240, 0.45);
    pointer-events: none;
  }
  .rt-search input {
    width: 100%;
    padding: 0.65rem 1rem 0.65rem 2.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: #faf6f0;
    background: rgba(250, 246, 240, 0.06);
    border: 1px solid rgba(250, 246, 240, 0.16);
    border-radius: 999px;
    transition:
      border-color var(--transition),
      background var(--transition);
  }
  .rt-search input::placeholder {
    color: rgba(250, 246, 240, 0.4);
  }
  .rt-search input:focus {
    outline: none;
    border-color: var(--color-gold);
    background: rgba(250, 246, 240, 0.1);
  }

  .rt-chips {
    display: flex;
    gap: var(--space-2);
  }
  .rt-chip {
    padding: 0.5rem 1.1rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(250, 246, 240, 0.65);
    background: transparent;
    border: 1px solid rgba(250, 246, 240, 0.2);
    border-radius: 999px;
    cursor: pointer;
    transition:
      color var(--transition),
      border-color var(--transition),
      background var(--transition);
  }
  .rt-chip:hover {
    color: #faf6f0;
    border-color: rgba(201, 168, 76, 0.6);
  }
  .rt-chip.is-active {
    color: #1a2a3a;
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  .rt-count {
    margin: 0 0 0 auto;
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    color: #faf6f0;
  }
  .rt-count-rest {
    color: rgba(250, 246, 240, 0.4);
  }

  /* ---- Table ---- */
  .rt-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .rt-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .rt-table th {
    padding: var(--space-3) var(--space-4);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-align: left;
    color: rgba(250, 246, 240, 0.5);
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid rgba(201, 168, 76, 0.25);
    white-space: nowrap;
  }
  .rt-table td {
    padding: var(--space-3) var(--space-4);
    color: rgba(250, 246, 240, 0.88);
    border-bottom: 1px solid rgba(250, 246, 240, 0.07);
    white-space: nowrap;
  }
  .rt-table th:first-child,
  .rt-table td:first-child {
    padding-left: var(--space-7);
  }
  .rt-table th:last-child,
  .rt-table td:last-child {
    padding-right: var(--space-7);
  }
  .rt-table tbody tr {
    transition: background var(--transition);
  }
  .rt-table tbody tr:hover {
    background: rgba(250, 246, 240, 0.05);
  }
  .rt-table .num {
    font-variant-numeric: tabular-nums;
  }
  .rt-table .place {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.06em;
    position: relative;
  }
  .rt-table .loops {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.06em;
    color: var(--color-gold);
  }
  .rt-table .name {
    font-weight: 500;
    color: #faf6f0;
  }
  .rt-table .dim {
    color: rgba(250, 246, 240, 0.55);
  }

  .rt-badge {
    display: inline-block;
    margin-left: var(--space-3);
    padding: 0.18rem 0.6rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid rgba(201, 168, 76, 0.55);
    border-radius: 999px;
    vertical-align: middle;
  }
  .rt-status {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: rgba(250, 246, 240, 0.55);
    border: 1px solid rgba(250, 246, 240, 0.18);
    border-radius: var(--radius-sm);
  }

  /* ---- Podium rows ---- */
  .rt-medal {
    display: inline-block;
    width: 13px;
    height: 13px;
    margin-right: 0.45rem;
    border-radius: 50%;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.45);
    vertical-align: 1px;
  }
  tr.is-gold .rt-medal {
    background: linear-gradient(135deg, #f3d27a, #c9963c);
  }
  tr.is-silver .rt-medal {
    background: linear-gradient(135deg, #dedede, #9c9c9c);
  }
  tr.is-bronze .rt-medal {
    background: linear-gradient(135deg, #d9924b, #8d4d1c);
  }
  tr.is-gold td {
    background: rgba(201, 168, 76, 0.12);
  }
  tr.is-silver td {
    background: rgba(222, 222, 222, 0.07);
  }
  tr.is-bronze td {
    background: rgba(217, 146, 75, 0.08);
  }
  tr.is-gold .place,
  tr.is-gold .name {
    color: var(--color-gold);
  }

  /* Staggered entrance for the leading rows.
     Pure CSS keyframes (fill: both) — content stays visible without JS,
     and the block below disables it entirely for reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    .rt-table tbody tr[style] {
      animation: rt-row-in 700ms var(--ease-emphasis) both;
      animation-delay: var(--d, 0ms);
    }
    @keyframes rt-row-in {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
  }

  .rt-empty {
    margin: 0;
    padding: var(--space-6) var(--space-7);
    color: rgba(250, 246, 240, 0.6);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .rt-head {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-6) var(--space-5) var(--space-4);
    }
    .rt-head-stat {
      display: none;
    }
    .rt-toolbar {
      padding: 0 var(--space-5) var(--space-5);
    }
    .rt-count {
      margin-left: 0;
    }
    .rt-table th:first-child,
    .rt-table td:first-child {
      padding-left: var(--space-5);
    }
    .rt-table th:last-child,
    .rt-table td:last-child {
      padding-right: var(--space-5);
    }
    .rt-empty {
      padding: var(--space-5);
    }
  }
</style>
