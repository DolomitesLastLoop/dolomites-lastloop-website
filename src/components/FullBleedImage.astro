---
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
  src?: string;
  alt?: string;
}
const { lang, src = "/images/day-running-2.jpg", alt = "" } = Astro.props;
const t = useTranslations(lang);
---

<section class="fb" aria-hidden={alt ? undefined : "true"}>
  <div class="fb-stage" data-fb-parallax>
    <img src={src} alt={alt} loading="lazy" />
  </div>
  <span class="fb-credit">{t("fullbleed.credit")}</span>
</section>

<style>
  .fb {
    position: relative;
    width: 100%;
    height: 70vh;
    overflow: hidden;
    isolation: isolate;
    background: #0a0a0a;
  }
  .fb-stage {
    position: absolute;
    inset: -10% 0;
    will-change: transform;
  }
  .fb-stage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .fb-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }
  @media (prefers-reduced-motion: reduce) {
    .fb-stage {
      transform: none !important;
    }
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>("[data-fb-parallax]");
  const section = stage?.parentElement;
  if (stage && section && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        const rect = section.getBoundingClientRect();
        // distance the centre of the section is from the viewport centre
        const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * 0.3;
        stage.style.transform = `translate3d(0, ${-offset}px, 0)`;
        raf = 0;
      });
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
