---
import { Image } from "astro:assets";
import { useTranslations, type Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
  src?: ImageMetadata | string;
  alt?: string;
  position?: string;
  height?: string;
}
const {
  lang,
  src = "/images/day-running-2.jpg",
  alt = "",
  position = "center center",
  height = "70vh",
} = Astro.props;
const t = useTranslations(lang);
// ImageMetadata → optimiertes <Image> (WebP); String-Pfade (public/) → <img>.
const optimized = typeof src !== "string";
---

<section class="fb" aria-hidden={alt ? undefined : "true"} style={`--fb-height:${height}`}>
  <div class="fb-stage" data-fb-parallax>
    {optimized ? (
      <Image
        src={src as ImageMetadata}
        alt={alt}
        widths={[640, 1024, 1600]}
        sizes="100vw"
        format="webp"
        quality={68}
        loading="lazy"
        decoding="async"
        style={`object-position:${position}`}
      />
    ) : (
      <img src={src as string} alt={alt} loading="lazy" decoding="async" style={`object-position:${position}`} />
    )}
  </div>
  <div class="fb-flash" data-photo-flash aria-hidden="true"></div>
  <span class="fb-credit">{t("fullbleed.credit")}</span>
</section>

<style>
  .fb {
    position: relative;
    width: 100%;
    height: var(--fb-height, 70vh);
    overflow: hidden;
    isolation: isolate;
    background: var(--color-bg-alt);
  }
  .fb-stage {
    position: absolute;
    inset: -15% 0; /* buffer for the GSAP parallax (yPercent ±10) */
    will-change: transform;
  }
  .fb-stage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .fb-flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(74, 127, 165, 0.9), rgba(45, 74, 107, 0.95));
    opacity: 0; /* Flash-Einblendung via GSAP onEnter (cinematic.ts) */
    pointer-events: none;
  }
  .fb-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }
  @media (prefers-reduced-motion: reduce) {
    .fb-stage {
      transform: none !important;
    }
  }
</style>
<!-- Parallax wird zentral in scripts/cinematic.ts über [data-fb-parallax] gesteuert -->

