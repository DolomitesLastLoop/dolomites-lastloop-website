# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_EARLY_BIRD=price_xxx
STRIPE_PRICE_STANDARD=price_xxx

# Resend (Bestätigungs-Email)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Dolomites Last Loop <noreply@dolomiteslastloop.com>"
EMAIL_REPLY_TO=dolomiteslastloop@gmail.com

# Admin
ADMIN_PASSWORD=change-me-strong
ADMIN_SESSION_SECRET=random-long-secret-min-32-chars

# Site
PUBLIC_SITE_URL=https://www.dolomiteslastloop.com
MAX_PARTICIPANTS=150

# Feature-Flag öffentliche Anmeldung: 'true' schaltet /[lang]/anmeldung live.
# Fehlt der Wert oder ist er ungleich 'true', zeigt /anmeldung "öffnet in Kürze".
# Der volle Flow ist immer unter /[lang]/anmeldung-test testbar (unverlinkt, noindex).
PUBLIC_REGISTRATION_ENABLED=false

# Upstash Redis – Rate-Limiting öffentlicher API-Endpoints (Free Tier reicht).
# Werte aus dem Upstash-Dashboard; fehlen sie, ist Rate-Limiting fail-open (aus).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Brevo Newsletter – Kontakt-Eintrag via /api/newsletter.
# API-Key aus Brevo → SMTP & API → API Keys. LIST_ID ist die numerische
# Listen-ID (NUR Ziffern, kein "#" – dotenv schneidet sonst ab "#" ab).
# Fehlen die Werte, wird Brevo übersprungen (Supabase-Eintrag bleibt aktiv).
BREVO_API_KEY=xkeysib-your-api-key
BREVO_LIST_ID=3
